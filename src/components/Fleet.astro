---
import { bikes } from '../data/bikes';
import BikeCard from './BikeCard.astro';
import BrandBar from './BrandBar.astro';

interface Props {
  preview?: boolean;
}

const { preview = false } = Astro.props;
const displayBikes = preview ? bikes.slice(0, 3) : bikes;
---

<section id="fleet" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="mb-12 reveal">
      <span class="text-xs font-mono uppercase tracking-widest text-accent">Motorräder</span>
      <h2 class="font-display text-4xl md:text-5xl font-normal mb-4 mt-2"
          data-i18n-de="Fleet"
          data-i18n-en="Fleet"
      >Fleet</h2>
      <p class="font-body text-text-secondary text-lg max-w-2xl"
         data-i18n-de="Neun Motorräder, gewartet auf Touring-Standard. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung."
         data-i18n-en="Nine motorcycles, maintained to touring standard. Each rental includes daily comprehensive insurance — ride without worry."
      >
        Neun Motorräder, gewartet auf Touring-Standard. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung.
      </p>
    </div>

    {!preview && (
      <div class="mb-16 py-8 border-y border-border-subtle">
        <p class="text-center text-xs font-mono text-text-muted uppercase tracking-widest mb-6"
           data-i18n-de="Marken in unserer Fleet"
           data-i18n-en="Brands in our fleet"
        >Marken in unserer Fleet</p>
        <BrandBar />
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 reveal">
      {displayBikes.map((bike) => (
        <BikeCard bike={bike} />
      ))}
    </div>

    {preview && (
      <div class="mt-12 text-center">
        <a
          href="/fleet"
          class="inline-block px-8 py-3 border border-border text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:border-accent hover:text-accent transition-colors duration-300"
          data-i18n-de="Alle Bikes ansehen"
          data-i18n-en="View all bikes"
        >
          Alle Bikes ansehen
        </a>
      </div>
    )}
  </div>
</section>
