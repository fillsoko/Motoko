---
import { Image } from 'astro:assets';
import { bikes } from '../data/bikes';
import BikeCard from './BikeCard.astro';
import BrandBar from './BrandBar.astro';
import FadeIn from './motion/FadeIn';
import bgImage from '../assets/images/sections/fleet-preview-bg.webp';

interface Props {
  preview?: boolean;
}

const { preview = false } = Astro.props;
const displayBikes = preview ? bikes.slice(0, 3) : bikes;
---

<section id="fleet" class="relative py-24 px-6 overflow-hidden">
  {preview && (
    <div class="absolute inset-0" aria-hidden="true">
      <Image
        src={bgImage}
        alt=""
        class="w-full h-full object-cover grayscale opacity-10"
        widths={[800, 1200, 1920]}
        sizes="100vw"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-bg-primary/85 to-bg-primary"></div>
    </div>
  )}

  <div class="relative z-10 max-w-6xl mx-auto">
    <FadeIn client:visible direction="up">
      <div class="mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-accent">Motorräder</span>
        <h2 class="font-display text-4xl md:text-5xl font-normal mb-4 mt-2"
            data-i18n-de="Fleet"
            data-i18n-en="Fleet"
        >Fleet</h2>
        <p class="font-body text-text-secondary text-lg max-w-2xl"
           data-i18n-de="Zehn Motorräder, gewartet auf Touring-Standard. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung."
           data-i18n-en="Ten motorcycles, maintained to touring standard. Each rental includes daily comprehensive insurance — ride without worry."
        >
          Zehn Motorräder, gewartet auf Touring-Standard. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung.
        </p>
      </div>
    </FadeIn>

    {!preview && (
      <div class="mb-16 py-8 border-y border-border-subtle">
        <p class="text-center text-xs font-mono text-text-muted uppercase tracking-widest mb-6"
           data-i18n-de="Marken in unserer Fleet"
           data-i18n-en="Brands in our fleet"
        >Marken in unserer Fleet</p>
        <BrandBar />
      </div>
    )}

    <FadeIn client:visible direction="up" delay={0.15}>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {displayBikes.map((bike) => (
          <BikeCard bike={bike} />
        ))}
      </div>
    </FadeIn>

    {preview && (
      <FadeIn client:visible direction="up" delay={0.3}>
        <div class="mt-12 text-center">
          <a
            href="/fleet"
            class="inline-block px-8 py-3 border border-border text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:border-accent hover:text-accent transition-colors duration-300"
            data-i18n-de="Alle Bikes ansehen"
            data-i18n-en="View all bikes"
          >
            Alle Bikes ansehen
          </a>
        </div>
      </FadeIn>
    )}
  </div>
</section>
