---
const links = [
  { label: 'Fleet', href: '#fleet' },
  { label: 'Tours', href: '#tours' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/90 backdrop-blur-sm border-b border-border-subtle">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#hero" class="font-display text-2xl font-light tracking-wide text-text-primary">
      motoko
    </a>

    <div class="hidden md:flex items-center gap-8">
      <ul class="flex items-center gap-8">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-body font-medium uppercase tracking-widest text-text-secondary hover:text-text-primary transition-colors duration-300"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Language switcher -->
      <div class="flex items-center gap-1 border-l border-border-subtle pl-6">
        <button
          id="lang-de"
          class="text-xs font-mono uppercase tracking-wider px-2 py-1 rounded text-text-primary bg-bg-surface"
          aria-label="Deutsch"
        >
          DE
        </button>
        <button
          id="lang-en"
          class="text-xs font-mono uppercase tracking-wider px-2 py-1 rounded text-text-muted hover:text-text-secondary transition-colors duration-300"
          aria-label="English"
        >
          EN
        </button>
      </div>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-text-secondary hover:text-text-primary transition-colors duration-300"
      aria-label="Menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border-subtle bg-bg-primary/95 backdrop-blur-sm">
    <div class="px-6 py-4 space-y-4">
      {links.map((link) => (
        <a
          href={link.href}
          class="block text-sm font-body font-medium uppercase tracking-widest text-text-secondary hover:text-text-primary transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
      <div class="flex items-center gap-2 pt-2 border-t border-border-subtle">
        <button class="text-xs font-mono uppercase tracking-wider px-2 py-1 rounded text-text-primary bg-bg-surface">DE</button>
        <button class="text-xs font-mono uppercase tracking-wider px-2 py-1 rounded text-text-muted">EN</button>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
