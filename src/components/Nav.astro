---
const links = [
  { labelDe: 'Fuhrpark', labelEn: 'Fleet', href: '/fleet' },
  { labelDe: 'Touren', labelEn: 'Tours', href: '/tours' },
  { labelDe: 'Preise', labelEn: 'Pricing', href: '/pricing' },
  { labelDe: 'Gästebuch', labelEn: 'Guestbook', href: '/testimonials' },
  { labelDe: 'Anfrage', labelEn: 'Request', href: '/anfrage' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/90 backdrop-blur-sm border-b border-border-subtle">
  <div class="max-w-6xl mx-auto px-4 py-4 sm:px-6 flex items-center justify-between">
    <a href="/" class="wordmark text-[2rem] leading-none sm:text-[2.4rem] md:text-[2.7rem] text-text-primary">
      motoko
    </a>

    <div class="hidden md:flex items-center gap-8">
      <ul class="flex items-center gap-8">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              data-href-de={link.href}
              data-href-en={link.href}
              class="text-sm font-body font-medium uppercase tracking-widest text-text-secondary hover:text-accent transition-colors duration-300"
              data-i18n-de={link.labelDe}
              data-i18n-en={link.labelEn}
            >
              {link.labelDe}
            </a>
          </li>
        ))}
      </ul>

      <!-- Language switcher -->
      <div class="flex items-center gap-1 border-l border-border-subtle pl-6">
        <button
          data-lang-btn="de"
          class="lang-btn text-xs font-mono uppercase tracking-wider px-2 py-1 rounded bg-accent text-text-primary"
          aria-label="Deutsch"
        >
          DE
        </button>
        <button
          data-lang-btn="en"
          class="lang-btn text-xs font-mono uppercase tracking-wider px-2 py-1 rounded text-text-muted hover:text-text-secondary transition-colors duration-300"
          aria-label="English"
        >
          EN
        </button>
      </div>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden rounded border border-border-subtle p-2 text-text-secondary hover:text-text-primary transition-colors duration-300"
      aria-label="Menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border-subtle bg-bg-primary/95 backdrop-blur-sm">
    <div class="px-4 py-4 space-y-4 sm:px-6">
      {links.map((link) => (
        <a
          href={link.href}
          data-href-de={link.href}
          data-href-en={link.href}
          class="block text-sm font-body font-medium uppercase tracking-widest text-text-secondary hover:text-accent transition-colors duration-300"
          data-i18n-de={link.labelDe}
          data-i18n-en={link.labelEn}
        >
          {link.labelDe}
        </a>
      ))}
      <div class="flex items-center gap-2 pt-2 border-t border-border-subtle">
        <button data-lang-btn="de" class="lang-btn text-xs font-mono uppercase tracking-wider px-2 py-1 rounded bg-accent text-text-primary">DE</button>
        <button data-lang-btn="en" class="lang-btn text-xs font-mono uppercase tracking-wider px-2 py-1 rounded text-text-muted">EN</button>
      </div>
    </div>
  </div>
</nav>

<script>
  function setLang(lang: string) {
    // Update all translatable elements
    document.querySelectorAll('[data-i18n-de]').forEach((el) => {
      const text = (el as HTMLElement).dataset[`i18n${lang === 'de' ? 'De' : 'En'}`];
      if (text) el.textContent = text;
    });

    document.querySelectorAll('[data-href-de]').forEach((el) => {
      const href = (el as HTMLElement).dataset[lang === 'de' ? 'hrefDe' : 'hrefEn'];
      if (href) {
        (el as HTMLAnchorElement).href = href;
      }
    });

    // Update button styles
    document.querySelectorAll('.lang-btn').forEach((btn) => {
      const btnLang = (btn as HTMLElement).dataset.langBtn;
      if (btnLang === lang) {
        btn.classList.remove('text-text-muted');
        btn.classList.add('text-text-primary', 'bg-accent');
      } else {
        btn.classList.remove('text-text-primary', 'bg-accent');
        btn.classList.add('text-text-muted');
      }
    });

    // Update html lang attribute
    document.documentElement.lang = lang;

    // Persist choice
    localStorage.setItem('motoko-lang', lang);
  }

  // Language button clicks
  document.querySelectorAll('.lang-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const lang = (btn as HTMLElement).dataset.langBtn!;
      setLang(lang);
    });
  });

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });

  // Restore saved language
  const saved = localStorage.getItem('motoko-lang');
  if (saved && saved !== 'de') {
    setLang(saved);
  }
</script>
