---
import { gear } from '../data/gear';
---

<section class="bg-[#070707] py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="mb-12 reveal">
      <span class="text-xs font-mono uppercase tracking-widest text-accent"
        data-i18n-de="Ausrüstung"
        data-i18n-en="Gear"
      >Ausrüstung</span>
      <h2 class="font-display text-4xl md:text-5xl font-normal mb-4 mt-2"
        data-i18n-de="Zubehör & Ausrüstung"
        data-i18n-en="Accessories & Gear"
      >Zubehör & Ausrüstung</h2>
      <p class="font-body text-text-secondary text-lg max-w-2xl"
        data-i18n-de="Alles was du für die Tour brauchst. Einiges ist inklusive, anderes gegen Aufpreis verfügbar."
        data-i18n-en="Everything you need for the ride. Some items are included, others available for a fee."
      >Alles was du für die Tour brauchst. Einiges ist inklusive, anderes gegen Aufpreis verfügbar.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 reveal">
      {gear.map((item) => (
        <div class="bg-bg-surface border border-border rounded-lg overflow-hidden hover:border-text-muted transition-colors duration-300">
          <div class="aspect-[4/3] bg-bg-surface-alt flex items-center justify-center">
            {item.icon === 'helmet' && (
              <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 3C7.03 3 3 7.03 3 12c0 2.76 1.24 5.23 3.19 6.88L6 21h12l-.19-2.12A8.967 8.967 0 0021 12c0-4.97-4.03-9-9-9z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 15h6" />
              </svg>
            )}
            {item.icon === 'jacket' && (
              <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 3l-4 2-4 1v10l4 2h8l4-2V6l-4-1-4-2z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 3v18" />
              </svg>
            )}
            {item.icon === 'bag' && (
              <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7H4a1 1 0 00-1 1v12a1 1 0 001 1h16a1 1 0 001-1V8a1 1 0 00-1-1z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" />
              </svg>
            )}
            {item.icon === 'phone' && (
              <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            )}
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-display text-lg font-normal"
                data-i18n-de={item.nameDe}
                data-i18n-en={item.nameEn}
              >{item.nameDe}</h3>
              {item.included ? (
                <span class="text-xs font-mono uppercase tracking-wider text-accent"
                  data-i18n-de="Inklusive"
                  data-i18n-en="Included"
                >Inklusive</span>
              ) : (
                <span class="text-xs font-mono text-text-muted">+{item.price} € / Tag</span>
              )}
            </div>
            <p class="font-body text-text-secondary text-sm leading-relaxed"
              data-i18n-de={item.descDe}
              data-i18n-en={item.descEn}
            >{item.descDe}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
