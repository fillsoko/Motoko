---
import { testimonials } from '../data/testimonials';
import FadeIn from './motion/FadeIn';

interface Props {
  hideIntro?: boolean;
}

const { hideIntro = false } = Astro.props;

function buildRow(offset: number) {
  return testimonials.map((_, index) => testimonials[(index + offset) % testimonials.length]);
}

const rows = [buildRow(0), buildRow(3), buildRow(6), buildRow(1)];
---

<section id="testimonials" class="overflow-hidden bg-[#050505] px-4 py-20 sm:px-6 md:py-24">
  <div class="mx-auto max-w-7xl">
    {!hideIntro && (
      <FadeIn client:visible direction="up">
        <div class="mb-16 text-center md:mb-20">
          <span
            class="text-xs font-mono uppercase tracking-[0.32em] text-accent"
            data-i18n-de="Gästebuch"
            data-i18n-en="Guestbook"
          >
            Gästebuch
          </span>
          <h2
            class="mt-4 font-display text-4xl font-light tracking-[0.06em] text-text-primary sm:text-5xl md:text-6xl"
            data-i18n-de="Stimmen unserer Fahrer"
            data-i18n-en="What Our Riders Say"
          >
            Stimmen unserer Fahrer
          </h2>
          <p
            class="mx-auto mt-5 max-w-2xl font-body text-base leading-relaxed text-text-secondary sm:text-lg"
            data-i18n-de="Echte Stimmen aus der motoko Community. Keine statische Wand, sondern ein laufender Strom aus Erfahrungen, Empfehlungen und Ride-Momenten."
            data-i18n-en="Real voices from the motoko community. Not a static wall, but a moving stream of experiences, recommendations, and ride moments."
          >
            Echte Stimmen aus der motoko Community. Keine statische Wand, sondern ein laufender Strom aus Erfahrungen, Empfehlungen und Ride-Momenten.
          </p>
        </div>
      </FadeIn>
    )}

    <FadeIn client:visible direction="up" delay={0.12}>
      <div class="relative overflow-hidden rounded-[2rem] border border-border bg-[radial-gradient(circle_at_top_left,rgba(255,107,0,0.12),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.05),transparent_24%),linear-gradient(180deg,#111111_0%,#050505_100%)] px-3 py-4 sm:px-4 sm:py-5 md:px-6 md:py-6">
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-10 bg-gradient-to-r from-[#050505] to-transparent sm:w-16 md:w-24"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-10 bg-gradient-to-l from-[#050505] to-transparent sm:w-16 md:w-24"></div>

        <div class="space-y-3 sm:space-y-4 md:space-y-5">
          {rows.map((row, rowIndex) => (
            <div class="testimonial-marquee-row">
              <div class:list={[
                'testimonial-marquee-track flex w-max gap-3 sm:gap-4 md:gap-5',
                rowIndex % 2 === 0 ? 'testimonial-marquee-track-left' : 'testimonial-marquee-track-right',
              ]}>
                {[0, 1].map(() => (
                  <div class="flex w-max gap-3 sm:gap-4 md:gap-5">
                    {row.map((testimonial) => (
                      <article class="testimonial-tile flex min-h-[15rem] w-[18rem] shrink-0 flex-col justify-between rounded-[1.4rem] border border-white/8 bg-white/[0.04] p-5 shadow-[0_12px_34px_rgba(0,0,0,0.18)] backdrop-blur-sm transition-colors duration-300 hover:border-accent/40 hover:bg-white/[0.06] sm:w-[21rem] sm:p-6 md:min-h-[16rem] md:w-[24rem]">
                        <div>
                          <div class="mb-4 flex items-center justify-between gap-4">
                            <div class="flex items-center gap-3">
                              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-accent/30 bg-accent/12">
                                <span class="font-body text-sm font-medium text-accent">{testimonial.name.charAt(0)}</span>
                              </div>
                              <div>
                                <p class="font-body text-sm font-medium text-text-primary sm:text-base">{testimonial.name}</p>
                                <p class="font-mono text-[10px] uppercase tracking-[0.24em] text-text-muted">via RIBE</p>
                              </div>
                            </div>
                            <div class="flex gap-0.5 text-accent">
                              {[1, 2, 3, 4, 5].map(() => (
                                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                              ))}
                            </div>
                          </div>

                          <p
                            class="font-body text-sm leading-relaxed text-text-secondary sm:text-[0.95rem] md:text-base"
                            data-i18n-de={testimonial.text}
                            data-i18n-en={testimonial.textEn || testimonial.text}
                          >
                            &ldquo;{testimonial.text}&rdquo;
                          </p>
                        </div>

                        <div class="mt-6 border-t border-white/8 pt-4">
                          <p
                            class="font-mono text-[10px] uppercase tracking-[0.22em] text-text-muted"
                            data-i18n-de="Verifizierte motoko Miete"
                            data-i18n-en="Verified motoko rental"
                          >
                            Verifizierte motoko Miete
                          </p>
                        </div>
                      </article>
                    ))}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </FadeIn>

    <FadeIn client:visible direction="up" delay={0.22}>
      <div class="mt-10 text-center md:mt-12">
        <a
          href="https://www.ribeme.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-body text-text-muted transition-colors duration-300 hover:text-accent"
          data-i18n-de="Alle Bewertungen auf RIBE lesen"
          data-i18n-en="Read all reviews on RIBE"
        >
          <span data-i18n-de="Alle Bewertungen auf RIBE lesen" data-i18n-en="Read all reviews on RIBE">
            Alle Bewertungen auf RIBE lesen
          </span>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </FadeIn>
  </div>
</section>

<style>
  .testimonial-marquee-row {
    overflow: hidden;
  }

  .testimonial-marquee-track {
    will-change: transform;
  }

  .testimonial-marquee-track-left {
    animation: testimonial-marquee-left 58s linear infinite;
  }

  .testimonial-marquee-track-right {
    animation: testimonial-marquee-right 62s linear infinite;
  }

  @keyframes testimonial-marquee-left {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(calc(-50% - 0.625rem));
    }
  }

  @keyframes testimonial-marquee-right {
    from {
      transform: translateX(calc(-50% - 0.625rem));
    }

    to {
      transform: translateX(0);
    }
  }

  @media (min-width: 640px) {
    @keyframes testimonial-marquee-left {
      from {
        transform: translateX(0);
      }

      to {
        transform: translateX(calc(-50% - 0.75rem));
      }
    }

    @keyframes testimonial-marquee-right {
      from {
        transform: translateX(calc(-50% - 0.75rem));
      }

      to {
        transform: translateX(0);
      }
    }
  }

  @media (min-width: 768px) {
    @keyframes testimonial-marquee-left {
      from {
        transform: translateX(0);
      }

      to {
        transform: translateX(calc(-50% - 0.875rem));
      }
    }

    @keyframes testimonial-marquee-right {
      from {
        transform: translateX(calc(-50% - 0.875rem));
      }

      to {
        transform: translateX(0);
      }
    }
  }
</style>
