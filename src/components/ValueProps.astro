---
const props = [
  {
    titleDe: 'Europaweite Vollkasko',
    titleEn: 'EU-Wide Full Coverage',
    descDe: 'Jede Miete beinhaltet eine tägliche Vollkaskoversicherung mit europaweiter Deckung.',
    descEn: 'Every rental includes daily comprehensive insurance with Europe-wide coverage.',
    icon: 'shield',
  },
  {
    titleDe: 'Handverlesene Fleet',
    titleEn: 'Curated Fleet',
    descDe: 'Neun ausgewählte Motorräder von sieben Herstellern — gewartet auf Touring-Standard.',
    descEn: 'Nine curated motorcycles from seven manufacturers — maintained to touring standard.',
    icon: 'motorcycle',
  },
  {
    titleDe: 'Flexible Buchung',
    titleEn: 'Flexible Booking',
    descDe: 'Buche über die RIBE-Plattform oder direkt bei uns — wie es dir am besten passt.',
    descEn: 'Book via the RIBE platform or directly with us — whatever suits you best.',
    icon: 'calendar',
  },
];
---

<section class="py-24 px-6 border-t border-border-subtle">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {props.map((prop) => (
        <div class="text-center md:text-left">
          <div class="inline-flex items-center justify-center w-10 h-10 md:w-12 md:h-12 mb-6 rounded-lg bg-accent-muted">
            {prop.icon === 'shield' && (
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            )}
            {prop.icon === 'motorcycle' && (
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6l-4 2v4l7 4" />
              </svg>
            )}
            {prop.icon === 'calendar' && (
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            )}
          </div>
          <h3
            class="font-display text-xl font-normal mb-3"
            data-i18n-de={prop.titleDe}
            data-i18n-en={prop.titleEn}
          >
            {prop.titleDe}
          </h3>
          <p
            class="font-body text-text-secondary text-sm leading-relaxed"
            data-i18n-de={prop.descDe}
            data-i18n-en={prop.descEn}
          >
            {prop.descDe}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
