---
import BrandBar from './BrandBar.astro';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Placeholder image: dark grey box at 16:9 -->
  <div class="absolute inset-0 bg-bg-surface" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/40 to-transparent"></div>
  </div>

  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
    <h1 class="font-display font-light text-6xl md:text-8xl lg:text-9xl tracking-wide mb-6">
      motoko
    </h1>
    <p class="font-body text-text-secondary text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed"
       data-i18n-de="Motorradverleih, geführte Touren und Custom Parts — mit Sitz in Frankfurt am Main. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung."
       data-i18n-en="Motorcycle rental, guided tours, and custom parts — based in Frankfurt, Germany. Every rental includes daily comprehensive insurance."
    >
      Motorradverleih, geführte Touren und Custom Parts — mit Sitz in Frankfurt am Main. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#fleet"
        class="inline-block px-8 py-3 bg-text-primary text-bg-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-text-secondary transition-colors duration-300"
        data-i18n-de="Fleet entdecken"
        data-i18n-en="Explore Fleet"
      >
        Fleet entdecken
      </a>
      <a
        href="https://www.ribeme.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-3 border border-border text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300"
        data-i18n-de="Buchen via RIBE"
        data-i18n-en="Book via RIBE"
      >
        Buchen via RIBE
      </a>
    </div>

    <!-- Brand logos -->
    <div class="mt-16 w-full max-w-3xl mx-auto">
      <BrandBar />
    </div>
  </div>
</section>
