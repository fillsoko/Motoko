---
import { Image } from 'astro:assets';
import BrandLogoGrid from './BrandLogoGrid.astro';
import FadeIn from './motion/FadeIn';
import ScrollCue from './ScrollCue.astro';
import heroBuell from '../../Graphics/Website/Hero_Buell XB12 SCG_v01.png';
import heroBmw from '../../Graphics/Website/Hero_BMW R 1200 GS.png';
import heroDucati from '../../Graphics/Website/Hero_Ducati 900 SS.png';
import heroHonda from '../../Graphics/Website/Hero_Honda F6C Gold Wing Valkyrie.png';
import heroHusqvarna from '../../Graphics/Website/Hero_Husqvarna Vitpilen 701.png';
import heroKawasaki from '../../Graphics/Website/Hero_Kawasaki Zephyr 1100.png';
import heroRocket from '../../Graphics/Website/Hero_Triumph Rocket 3R.png';
import heroSpeedTriple from '../../Graphics/Website/Hero_Triumph Speed Triple.png';

const heroImages = [
  { src: heroBuell, focus: '35% 50%' },
  { src: heroBmw, focus: '60% 50%' },
  { src: heroDucati, focus: '45% 50%' },
  { src: heroHonda, focus: '30% 50%' },
  { src: heroHusqvarna, focus: '45% 50%' },
  { src: heroKawasaki, focus: '30% 50%' },
  { src: heroRocket, focus: '40% 50%' },
  { src: heroSpeedTriple, focus: '45% 50%' },
];
---

<section id="hero" class="relative min-h-screen flex items-end overflow-hidden">
  <div class="absolute inset-0" aria-hidden="true">
    {heroImages.map((item, index) => (
      <div class:list={['hero-rotator-slide absolute inset-0', index === 0 && 'is-active']} data-hero-slide>
        <Image
          src={item.src}
          alt=""
          class="w-full h-full object-cover md:!object-center"
          style={`object-position: ${item.focus}`}
          widths={[900, 1400, 2000]}
          sizes="100vw"
          loading={index === 0 ? 'eager' : 'lazy'}
        />
      </div>
    ))}
    <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/40 to-transparent"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pb-24 md:pb-28">
    <FadeIn client:load delay={0.3} direction="up" eager>
      <p class="font-body text-white text-base md:text-lg max-w-2xl mx-auto mb-8 leading-relaxed text-center"
         data-i18n-de="Motorradverleih, geführte Touren und Custom Parts — mit Sitz in Frankfurt am Main. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung."
         data-i18n-en="Motorcycle rental, guided tours, and custom parts — based in Frankfurt, Germany. Every rental includes daily comprehensive insurance."
      >
        Motorradverleih, geführte Touren und Custom Parts — mit Sitz in Frankfurt am Main. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung.
      </p>
    </FadeIn>
    <FadeIn client:load delay={0.5} direction="up" eager>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
        <a
          href="/anfrage"
          class="request-link inline-block px-8 py-3 bg-accent text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-accent-hover transition-colors duration-300"
          data-i18n-de="Buchen via motoko"
          data-i18n-en="Book via motoko"
        >
          Buchen via motoko
        </a>
        <a
          href="https://www.ribeme.com/de/profile/16127"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 border border-border text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300"
          data-i18n-de="Buchen via RIBE"
          data-i18n-en="Book via RIBE"
        >
          Buchen via RIBE
        </a>
      </div>
    </FadeIn>
    <FadeIn client:load delay={0.7} direction="up" eager>
      <div class="w-full max-w-6xl mx-auto">
        <p class="mb-4 text-center font-mono text-xs uppercase tracking-[0.35em] text-accent">
          Marken in unserem Fuhrpark
        </p>
        <BrandLogoGrid />
      </div>
    </FadeIn>
  </div>

  <ScrollCue />
</section>

<script>
  const slides = Array.from(document.querySelectorAll('[data-hero-slide]'));
  let activeIndex = 0;
  let rotationTimer;

  function showSlide(nextIndex) {
    slides.forEach((slide, index) => {
      slide.classList.toggle('is-active', index === nextIndex);
    });
    activeIndex = nextIndex;
  }

  function startRotation() {
    if (slides.length <= 1) return;
    window.clearInterval(rotationTimer);
    rotationTimer = window.setInterval(() => {
      showSlide((activeIndex + 1) % slides.length);
    }, 5200);
  }

  if (slides.length > 0) {
    showSlide(0);
    startRotation();

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        window.clearInterval(rotationTimer);
      } else {
        startRotation();
      }
    });
  }
</script>

<style>
  .hero-rotator-slide {
    opacity: 0;
    will-change: opacity;
    transition: opacity 1.2s ease;
  }

  .hero-rotator-slide.is-active {
    opacity: 1;
  }
</style>
