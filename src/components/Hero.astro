---
import { Image } from 'astro:assets';
import BrandLogoGrid from './BrandLogoGrid.astro';
import FadeIn from './motion/FadeIn';
import ScrollCue from './ScrollCue.astro';
import heroImage from '../assets/images/heroes/home.webp';
---

<section id="hero" class="relative min-h-screen flex items-end overflow-hidden">
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={heroImage}
      alt=""
      class="w-full h-full object-cover grayscale"
      widths={[800, 1200, 1920]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/40 to-transparent"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pb-24 md:pb-28">
    <FadeIn client:load delay={0.3} direction="up" eager>
      <p class="font-body text-text-secondary text-base md:text-lg max-w-2xl mx-auto mb-8 leading-relaxed text-center"
         data-i18n-de="Motorradverleih, geführte Touren und Custom Parts — mit Sitz in Frankfurt am Main. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung."
         data-i18n-en="Motorcycle rental, guided tours, and custom parts — based in Frankfurt, Germany. Every rental includes daily comprehensive insurance."
      >
        Motorradverleih, geführte Touren und Custom Parts — mit Sitz in Frankfurt am Main. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung.
      </p>
    </FadeIn>
    <FadeIn client:load delay={0.5} direction="up" eager>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
        <a
          href="/anfrage"
          class="request-link inline-block px-8 py-3 bg-accent text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-accent-hover transition-colors duration-300"
          data-i18n-de="Buchen via motoko"
          data-i18n-en="Book via motoko"
        >
          Buchen via motoko
        </a>
        <a
          href="https://www.ribeme.com/de/profile/16127"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 border border-border text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300"
          data-i18n-de="Buchen via RIBE"
          data-i18n-en="Book via RIBE"
        >
          Buchen via RIBE
        </a>
      </div>
    </FadeIn>
    <FadeIn client:load delay={0.7} direction="up" eager>
      <div class="w-full max-w-6xl mx-auto">
        <p class="mb-4 text-center font-mono text-xs uppercase tracking-[0.35em] text-accent">
          Marken in unserem Fuhrpark
        </p>
        <BrandLogoGrid />
      </div>
    </FadeIn>
  </div>

  <ScrollCue />
</section>
