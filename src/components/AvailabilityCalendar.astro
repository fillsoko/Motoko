---
import { availability } from '../data/availability';

const months = ['Jan', 'Feb', 'Mär', 'Apr', 'Mai', 'Jun', 'Jul', 'Aug', 'Sep', 'Okt', 'Nov', 'Dez'];
const monthsEn = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
---

<section class="bg-[#060606] py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="mb-12 reveal">
      <span class="text-xs font-mono uppercase tracking-widest text-accent"
        data-i18n-de="Saison"
        data-i18n-en="Season"
      >Saison</span>
      <h2 class="font-display text-4xl md:text-5xl font-normal mb-4 mt-2"
        data-i18n-de="Verfügbarkeit"
        data-i18n-en="Availability"
      >Verfügbarkeit</h2>
      <p class="font-body text-text-secondary text-lg max-w-2xl"
        data-i18n-de="Saisonale Verfügbarkeit unserer Motorräder. Für Reservierungen außerhalb der Saison kontaktiere uns direkt."
        data-i18n-en="Seasonal availability of our motorcycles. For off-season reservations, contact us directly."
      >Saisonale Verfügbarkeit unserer Motorräder. Für Reservierungen außerhalb der Saison kontaktiere uns direkt.</p>
    </div>

    <!-- Desktop calendar grid -->
    <div class="hidden md:block overflow-x-auto reveal">
      <table class="w-full">
        <thead>
          <tr class="border-b border-border">
            <th class="py-3 pr-4 text-left font-mono text-xs uppercase tracking-wider text-text-muted">Bike</th>
            {months.map((m, i) => (
              <th class="py-3 px-1 text-center font-mono text-xs uppercase tracking-wider text-text-muted w-12"
                data-i18n-de={m}
                data-i18n-en={monthsEn[i]}
              >{m}</th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-border-subtle">
          {availability.map((bike) => (
            <tr class="hover:bg-bg-surface transition-colors duration-200">
              <td class="py-3 pr-4">
                <a href={`/bikes/${bike.bikeSlug}`} class="font-body text-sm text-text-primary hover:text-accent transition-colors duration-300">
                  {bike.bikeName}
                </a>
              </td>
              {months.map((_, monthIdx) => (
                <td class="py-3 px-1 text-center">
                  <div class={`w-3 h-3 rounded-full mx-auto ${bike.availableMonths.includes(monthIdx + 1) ? 'bg-accent' : 'bg-border'}`}></div>
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Legend -->
    <div class="hidden md:flex items-center gap-6 mt-6 reveal">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-accent"></div>
        <span class="font-mono text-xs text-text-muted"
          data-i18n-de="Verfügbar"
          data-i18n-en="Available"
        >Verfügbar</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-border"></div>
        <span class="font-mono text-xs text-text-muted"
          data-i18n-de="Nicht verfügbar"
          data-i18n-en="Not available"
        >Nicht verfügbar</span>
      </div>
    </div>

    <!-- Mobile cards -->
    <div class="md:hidden space-y-4 reveal">
      {availability.map((bike) => (
        <div class="bg-bg-surface border border-border rounded-lg p-4">
          <a href={`/bikes/${bike.bikeSlug}`} class="font-body text-text-primary font-medium text-sm hover:text-accent transition-colors duration-300 block mb-3">
            {bike.bikeName}
          </a>
          <div class="flex flex-wrap gap-1.5">
            {months.map((m, monthIdx) => (
              <div class={`flex items-center justify-center w-10 h-7 rounded text-xs font-mono ${bike.availableMonths.includes(monthIdx + 1) ? 'bg-accent-muted text-accent' : 'bg-bg-surface-alt text-text-muted'}`}
                data-i18n-de={m}
                data-i18n-en={monthsEn[monthIdx]}
              >{m}</div>
            ))}
          </div>
          {bike.notesDe && (
            <p class="font-body text-text-muted text-xs mt-2"
              data-i18n-de={bike.notesDe}
              data-i18n-en={bike.notesEn || bike.notesDe}
            >{bike.notesDe}</p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
