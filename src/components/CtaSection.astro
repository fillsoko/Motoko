---
import { Image } from 'astro:assets';
import FadeIn from './motion/FadeIn';
import AnimatedText from './motion/AnimatedText';
import bgImage from '../assets/images/sections/cta-bg.webp';
---

<section class="relative py-32 px-6 overflow-hidden bg-[#020202]">
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={bgImage}
      alt=""
      class="w-full h-full object-cover grayscale opacity-25"
      widths={[800, 1200, 1920]}
      sizes="100vw"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#111111] via-[#020202]/74 to-[#000000]/84"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto text-center">
    <AnimatedText
      client:visible
      text="Motor starten."
      as="h2"
      className="font-display text-4xl md:text-6xl lg:text-7xl font-light mb-6 uppercase tracking-[0.08em]"
    />
    <FadeIn client:visible delay={0.3} direction="up">
      <p class="font-body text-text-secondary text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed"
         data-i18n-de="Zehn handverlesene Motorräder. Vollkasko inklusive. Ab Frankfurt am Main."
         data-i18n-en="Ten handpicked motorcycles. Full insurance included. From Frankfurt, Germany."
      >
        Zehn handverlesene Motorräder. Vollkasko inklusive. Ab Frankfurt am Main.
      </p>
    </FadeIn>
    <FadeIn client:visible delay={0.5} direction="up">
      <div class="flex flex-col sm:flex-row flex-wrap items-center justify-center gap-4">
        <a
          href="/fleet"
          class="inline-block px-10 py-4 bg-accent text-text-primary text-xs sm:text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-accent-hover transition-colors duration-300"
          data-i18n-de="Fuhrpark ansehen"
          data-i18n-en="View Fleet"
        >
          Fuhrpark ansehen
        </a>
        <a
          href="/#contact"
          class="inline-block px-10 py-4 border border-border text-text-primary text-xs sm:text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300"
          data-i18n-de="Anfrage starten"
          data-i18n-en="Send Inquiry"
        >
          Anfrage starten
        </a>
        <a
          href="https://www.ribeme.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-10 py-4 border border-border text-text-primary text-xs sm:text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300"
          data-i18n-de="Direkt buchen via RIBE"
          data-i18n-en="Book now via RIBE"
        >
          Direkt buchen via RIBE
        </a>
      </div>
    </FadeIn>
  </div>
</section>
