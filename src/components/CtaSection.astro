---
import { Image } from 'astro:assets';
import FadeIn from './motion/FadeIn';
import AnimatedText from './motion/AnimatedText';
import bgImage from '../assets/images/sections/cta-bg.webp';
---

<section class="relative py-32 px-6 overflow-hidden bg-[#020202]">
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={bgImage}
      alt=""
      class="w-full h-full object-cover grayscale opacity-45"
      widths={[800, 1200, 1920]}
      sizes="100vw"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#111111] via-[#020202]/74 to-[#000000]/84"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto text-center">
    <AnimatedText
      client:visible
      text="Motor starten."
      as="h2"
      className="font-display text-4xl md:text-6xl lg:text-7xl font-light mb-6 uppercase tracking-[0.08em]"
    />
    <FadeIn client:visible delay={0.3} direction="up">
      <p class="font-body text-text-secondary text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
        <span
          class="block"
          data-i18n-de="Zehn handverlesene Motorräder. Vollkasko inklusive."
          data-i18n-en="Ten handpicked motorcycles. Full insurance included."
        >
          Zehn handverlesene Motorräder. Vollkasko inklusive.
        </span>
        <span
          class="mt-1 block"
          data-i18n-de="Ab Frankfurt am Main."
          data-i18n-en="From Frankfurt, Germany."
        >
          Ab Frankfurt am Main.
        </span>
      </p>
    </FadeIn>
    <FadeIn client:visible delay={0.5} direction="up">
      <div class="flex flex-col sm:flex-row flex-wrap items-center justify-center gap-4">
        <a
          href="/anfrage"
          class="request-link inline-block min-w-[240px] px-10 py-4 bg-accent text-text-primary text-xs sm:text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-accent-hover transition-colors duration-300 text-center"
          data-i18n-de="Buchen via motoko"
          data-i18n-en="Book via motoko"
        >
          Buchen via motoko
        </a>
        <a
          href="https://www.ribeme.com/de/profile/16127"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block min-w-[240px] px-10 py-4 border border-border text-text-primary text-xs sm:text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300 text-center"
          data-i18n-de="Buchen via RIBE"
          data-i18n-en="Book via RIBE"
        >
          Buchen via RIBE
        </a>
      </div>
    </FadeIn>
  </div>
</section>
