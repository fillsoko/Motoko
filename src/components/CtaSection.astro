---

<section class="py-32 px-6 border-t border-border-subtle">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="font-display text-4xl md:text-6xl lg:text-7xl font-light mb-6"
        data-i18n-de="Motor starten."
        data-i18n-en="Start your engine."
    >
      Motor starten.
    </h2>
    <p class="font-body text-text-secondary text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed"
       data-i18n-de="Neun handverlesene Motorräder. Vollkasko inklusive. Ab Frankfurt am Main."
       data-i18n-en="Nine handpicked motorcycles. Full insurance included. From Frankfurt, Germany."
    >
      Neun handverlesene Motorräder. Vollkasko inklusive. Ab Frankfurt am Main.
    </p>
    <div class="flex flex-col sm:flex-row flex-wrap items-center justify-center gap-4">
      <a
        href="/fleet"
        class="inline-block px-10 py-4 bg-accent text-text-primary text-xs sm:text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-accent-hover transition-colors duration-300"
        data-i18n-de="Fleet ansehen"
        data-i18n-en="View Fleet"
      >
        Fleet ansehen
      </a>
      <a
        href="/#contact"
        class="inline-block px-10 py-4 border border-border text-text-primary text-xs sm:text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300"
        data-i18n-de="Anfrage starten"
        data-i18n-en="Send Inquiry"
      >
        Anfrage starten
      </a>
      <a
        href="https://www.ribeme.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-10 py-4 border border-border text-text-primary text-xs sm:text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300"
        data-i18n-de="Direkt buchen via RIBE"
        data-i18n-en="Book now via RIBE"
      >
        Direkt buchen via RIBE
      </a>
    </div>
  </div>
</section>
