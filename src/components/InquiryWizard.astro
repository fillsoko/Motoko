            <button
              id="wizard-back"
              class="invisible text-sm font-body text-text-muted transition-colors duration-300 hover:text-text-secondary"
            >
              Back
            </button>
            <div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #wizard-success {
    position: relative;
    overflow: hidden;
  }

  .wizard-confetti-piece {
    position: absolute;
    top: -12%;
    width: 10px;
    height: 18px;
    border-radius: 999px;
    opacity: 0.9;
    animation: wizard-confetti-fall 1400ms ease-out forwards !important;
    animation-duration: 1400ms !important;
    animation-iteration-count: 1 !important;
    will-change: transform, opacity;
  }

  @keyframes wizard-confetti-fall {
    0% {
      transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
      opacity: 0;
    }
    10% {
      opacity: 0.95;
    }
    100% {
      transform: translate3d(var(--confetti-x, 0), 320px, 0) rotate(var(--confetti-rotate, 180deg)) scale(0.92);
