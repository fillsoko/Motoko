---
import { Image } from 'astro:assets';
import bgImage from '../assets/images/sections/contact-bg.webp';
import { bikes } from '../data/bikes';

const RECIPIENT_EMAIL = 'hallo@motoko.de';
const EMAILJS_PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY || '';
const EMAILJS_SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID || '';
const EMAILJS_TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID || '';
const EMAILJS_TEMPLATE_ID_DE = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID_DE || '';
const EMAILJS_TEMPLATE_ID_EN = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID_EN || '';

const bikesForWizard = bikes.map((bike) => ({
  name: bike.name,
  slug: bike.slug,
  category: bike.category,
  brand: bike.name.split(' ')[0].toLowerCase() === 'harley-davidson' ? 'harley' : bike.name.split(' ')[0].toLowerCase(),
  pricePerDay: bike.pricePerDay,
  year: bike.year,
}));
---

<section id="contact" class="relative overflow-hidden bg-[#202020] px-4 py-20 sm:px-6 sm:py-24">
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={bgImage}
      alt=""
      class="h-full w-full object-cover grayscale opacity-10"
      widths={[800, 1200, 1920]}
      sizes="100vw"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#2b2b2b] via-[#202020]/60 to-[#141414]"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl">
    <div class="overflow-hidden rounded-[30px] border border-white/10 bg-[#0d0d0d]/90 shadow-[0_35px_80px_rgba(0,0,0,0.45)] backdrop-blur-xl">
      <div class="flex items-center gap-3 border-b border-white/10 px-4 py-4 sm:px-6">
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
          <span class="h-3 w-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
        </div>
        <div
          id="wizard-browser-label"
          class="ml-2 flex-1 rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-center font-mono text-[10px] uppercase tracking-[0.28em] text-text-muted sm:px-4 sm:text-[11px] sm:tracking-[0.32em]"
        >
          motoko://contact/inquiry
        </div>
      </div>

      <div class="grid lg:grid-cols-[320px_minmax(0,1fr)]">
        <aside class="overflow-hidden border-b border-white/10 bg-black/25 p-5 sm:p-8 lg:border-b-0 lg:border-r">
          <span
            id="wizard-kicker"
            class="text-xs font-mono uppercase tracking-[0.35em] text-accent"
          >
            Start here
          </span>
          <h2
            id="wizard-title"
            class="mt-4 font-display text-4xl font-semibold leading-none text-text-primary lg:text-5xl"
          >
            Inquiry
          </h2>
          <p
            id="wizard-intro"
            class="mt-5 max-w-sm font-body text-base leading-relaxed text-text-secondary md:text-lg"
          >
            Answer a few quick questions and we will get back to you.
          </p>

          <div class="mt-8 h-px w-full bg-white/10"></div>

          <div id="step-dots" class="mt-6 flex gap-2 overflow-x-auto pb-2 lg:mt-8 lg:grid lg:gap-2.5 lg:overflow-visible lg:pb-0"></div>

          <span id="step-label" class="mt-6 block font-mono text-xs uppercase tracking-[0.3em] text-accent lg:mt-8">
            Step 1 / 6
          </span>
        </aside>

        <div class="flex flex-col p-5 sm:p-8 md:p-10">
          <div data-step="1" class="wizard-step flex flex-1 flex-col">
            <h3 id="step-1-heading" class="mb-6 font-display text-3xl md:text-4xl">What are you looking for?</h3>
            <div class="grid flex-1 grid-cols-1 gap-4 md:grid-cols-3">
              <button data-choice="interest" data-value="bike" class="wizard-option flex items-start gap-4 rounded-2xl border border-border px-5 py-5 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="mt-0.5 h-6 w-6 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6l-4 2v4l7 4" />
                </svg>
                <div>
                  <span id="interest-bike-label" class="block font-body text-sm font-medium text-text-primary">Rent a motorcycle</span>
                  <span id="interest-bike-copy" class="mt-1 block font-body text-xs text-text-muted">I want to rent a specific bike</span>
                </div>
              </button>

              <button data-choice="interest" data-value="tour" class="wizard-option flex items-start gap-4 rounded-2xl border border-border px-5 py-5 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="mt-0.5 h-6 w-6 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
                <div>
                  <span id="interest-tour-label" class="block font-body text-sm font-medium text-text-primary">Guided tour</span>
                  <span id="interest-tour-copy" class="mt-1 block font-body text-xs text-text-muted">I want to join a guided motorcycle tour</span>
                </div>
              </button>

              <button data-choice="interest" data-value="both" class="wizard-option flex items-start gap-4 rounded-2xl border border-border px-5 py-5 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="mt-0.5 h-6 w-6 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                </svg>
                <div>
                  <span id="interest-both-label" class="block font-body text-sm font-medium text-text-primary">Open to both</span>
                  <span id="interest-both-copy" class="mt-1 block font-body text-xs text-text-muted">Show me the best fit</span>
                </div>
              </button>
            </div>
          </div>

          <div data-step="2" class="wizard-step hidden flex-1 flex-col">
            <h3 id="step-2-heading" class="mb-6 font-display text-3xl md:text-4xl">Do you have a preferred brand?</h3>
            <div class="grid flex-1 grid-cols-1 gap-4 sm:grid-cols-2 auto-rows-fr">
              <button data-choice="brand" data-value="bmw" class="wizard-option flex items-center gap-4 rounded-2xl border border-border px-5 py-4 text-left transition-colors duration-300 hover:border-text-muted">
                <img src="/images/logos/bmw.svg" alt="BMW" class="h-10 w-10 object-contain sm:h-12 sm:w-12" />
                <span class="font-body text-base font-medium text-text-primary">BMW</span>
              </button>
              <button data-choice="brand" data-value="triumph" class="wizard-option flex items-center gap-4 rounded-2xl border border-border px-5 py-4 text-left transition-colors duration-300 hover:border-text-muted">
                <img src="/images/logos/triumph.svg" alt="Triumph" class="h-10 w-10 object-contain brightness-0 invert sm:h-12 sm:w-12" />
                <span class="font-body text-base font-medium text-text-primary">Triumph</span>
              </button>
              <button data-choice="brand" data-value="ducati" class="wizard-option flex items-center gap-4 rounded-2xl border border-border px-5 py-4 text-left transition-colors duration-300 hover:border-text-muted">
                <img src="/images/logos/ducati.svg" alt="Ducati" class="h-10 w-10 object-contain brightness-0 invert sm:h-12 sm:w-12" />
                <span class="font-body text-base font-medium text-text-primary">Ducati</span>
              </button>
              <button data-choice="brand" data-value="harley" class="wizard-option flex items-center gap-4 rounded-2xl border border-border px-5 py-4 text-left transition-colors duration-300 hover:border-text-muted">
                <img src="/images/logos/harley-davidson.svg" alt="Harley-Davidson" class="h-10 w-10 object-contain brightness-0 invert sm:h-12 sm:w-12" />
                <span class="font-body text-base font-medium text-text-primary">Harley-Davidson</span>
              </button>
              <button data-choice="brand" data-value="honda" class="wizard-option flex items-center gap-4 rounded-2xl border border-border px-5 py-4 text-left transition-colors duration-300 hover:border-text-muted">
                <img src="/images/logos/honda.svg" alt="Honda" class="h-10 w-10 object-contain brightness-0 invert sm:h-12 sm:w-12" />
                <span class="font-body text-base font-medium text-text-primary">Honda</span>
              </button>
              <button data-choice="brand" data-value="other" class="wizard-option flex items-center gap-4 rounded-2xl border border-border px-5 py-4 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="h-10 w-10 shrink-0 text-text-muted sm:h-12 sm:w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span id="brand-other-label" class="font-body text-base font-medium text-text-primary">Other</span>
              </button>
              <button data-choice="brand" data-value="no-preference" class="wizard-option flex items-center gap-4 rounded-2xl border border-border px-5 py-4 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="h-10 w-10 shrink-0 text-text-muted sm:h-12 sm:w-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <span id="brand-any-label" class="block font-body text-base font-medium text-text-primary">No preference</span>
                  <span id="brand-any-copy" class="mt-0.5 block font-body text-xs text-text-muted">Show me the strongest fit</span>
                </div>
              </button>
            </div>
          </div>

          <div data-step="3" class="wizard-step hidden flex-1 flex-col">
            <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <h3 id="step-3-heading" class="font-display text-3xl md:text-4xl">Which bike model fits best?</h3>
                <p id="step-3-copy" class="mt-3 font-body text-sm leading-relaxed text-text-secondary">
                  Choose a motorcycle model so we can tailor the next steps.
                </p>
              </div>
              <div
                id="wizard-model-filter"
                class="rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 text-xs font-mono uppercase tracking-[0.24em] text-text-muted"
              ></div>
            </div>
            <div id="wizard-bike-grid" class="grid flex-1 grid-cols-1 gap-4 lg:grid-cols-2"></div>
          </div>

          <div data-step="4" class="wizard-step hidden flex-1 flex-col">
            <h3 id="step-4-heading" class="mb-6 font-display text-3xl md:text-4xl">How would you like to book?</h3>
            <div class="grid flex-1 grid-cols-1 gap-4 md:grid-cols-3">
              <button data-choice="booking" data-value="ribe" class="wizard-option flex items-start gap-4 rounded-2xl border border-border px-5 py-5 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="mt-0.5 h-6 w-6 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
                <div>
                  <span id="booking-ribe-label" class="block font-body text-sm font-medium text-text-primary">Via RIBE</span>
                  <span id="booking-ribe-copy" class="mt-1 block font-body text-xs text-text-muted">Online platform with Europe-wide fully comprehensive cover</span>
                </div>
              </button>
              <button data-choice="booking" data-value="direct" class="wizard-option flex items-start gap-4 rounded-2xl border border-border px-5 py-5 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="mt-0.5 h-6 w-6 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
                </svg>
                <div>
                  <span id="booking-direct-label" class="block font-body text-sm font-medium text-text-primary">Direct with motoko</span>
                  <span id="booking-direct-copy" class="mt-1 block font-body text-xs text-text-muted">Personal contact and individual coordination</span>
                </div>
              </button>
              <button data-choice="booking" data-value="unsure" class="wizard-option flex items-start gap-4 rounded-2xl border border-border px-5 py-5 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="mt-0.5 h-6 w-6 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <span id="booking-unsure-label" class="block font-body text-sm font-medium text-text-primary">I am not sure yet</span>
                  <span id="booking-unsure-copy" class="mt-1 block font-body text-xs text-text-muted">Advise me on the right setup</span>
                </div>
              </button>
            </div>
          </div>

          <div data-step="5" class="wizard-step hidden flex-1 flex-col">
            <h3 id="step-5-heading" class="mb-6 font-display text-3xl md:text-4xl">What kind of insurance do you need?</h3>
            <div class="grid flex-1 grid-cols-1 gap-4 md:grid-cols-3">
              <button data-choice="insurance" data-value="full" class="wizard-option flex items-start gap-4 rounded-2xl border border-border px-5 py-5 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="mt-0.5 h-6 w-6 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <div>
                  <span id="insurance-full-label" class="block font-body text-sm font-medium text-text-primary">Europe-wide fully comprehensive cover</span>
                  <span id="insurance-full-copy" class="mt-1 block font-body text-xs text-text-muted">Maximum protection, included with RIBE bookings</span>
                </div>
              </button>
              <button data-choice="insurance" data-value="basic" class="wizard-option flex items-start gap-4 rounded-2xl border border-border px-5 py-5 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="mt-0.5 h-6 w-6 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.618 5.984A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <div>
                  <span id="insurance-basic-label" class="block font-body text-sm font-medium text-text-primary">Liability only</span>
                  <span id="insurance-basic-copy" class="mt-1 block font-body text-xs text-text-muted">The minimum legal cover</span>
                </div>
              </button>
              <button data-choice="insurance" data-value="own" class="wizard-option flex items-start gap-4 rounded-2xl border border-border px-5 py-5 text-left transition-colors duration-300 hover:border-text-muted">
                <svg class="mt-0.5 h-6 w-6 shrink-0 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
                <div>
                  <span id="insurance-own-label" class="block font-body text-sm font-medium text-text-primary">My own insurance</span>
                  <span id="insurance-own-copy" class="mt-1 block font-body text-xs text-text-muted">I already have a preferred setup</span>
                </div>
              </button>
            </div>
          </div>

          <div data-step="6" class="wizard-step hidden flex-1 flex-col">
            <h3 id="step-6-heading" class="mb-6 font-display text-3xl md:text-4xl">Your details</h3>

            <div id="wizard-prefill" class="mb-6 hidden rounded-2xl border border-accent/30 bg-accent-muted/40 p-5">
              <p id="wizard-prefill-kicker" class="mb-1 font-mono text-xs uppercase tracking-[0.28em] text-accent">Direct request</p>
              <p id="wizard-prefill-title" class="font-display text-2xl text-text-primary"></p>
              <p id="wizard-prefill-copy" class="mt-2 font-body text-sm leading-relaxed text-text-secondary"></p>
            </div>

            <div class="mb-6 rounded-3xl border border-white/10 bg-white/[0.03] p-5 sm:p-6">
              <p id="wizard-summary-kicker" class="font-mono text-xs uppercase tracking-[0.28em] text-accent">Request summary</p>
              <ul id="wizard-summary-list" class="mt-4 space-y-3"></ul>
            </div>

            <form id="wizard-form" class="flex flex-1 flex-col space-y-4">
              <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div>
                  <label id="wizard-date-from-label" for="wiz-date-from" class="mb-1 block text-xs font-mono uppercase tracking-wider text-text-muted">From</label>
                  <input
                    type="date"
                    id="wiz-date-from"
                    name="rentalFrom"
                    class="w-full rounded-2xl border border-border bg-bg-surface-alt px-4 py-3 text-sm text-text-primary transition-colors duration-300 focus:border-text-muted focus:outline-none"
                  />
                </div>
                <div>
                  <label id="wizard-date-to-label" for="wiz-date-to" class="mb-1 block text-xs font-mono uppercase tracking-wider text-text-muted">To</label>
                  <input
                    type="date"
                    id="wiz-date-to"
                    name="rentalTo"
                    class="w-full rounded-2xl border border-border bg-bg-surface-alt px-4 py-3 text-sm text-text-primary transition-colors duration-300 focus:border-text-muted focus:outline-none"
                  />
                </div>
                <div>
                  <label id="wizard-duration-label" for="wiz-duration" class="mb-1 block text-xs font-mono uppercase tracking-wider text-text-muted">Days</label>
                  <input
                    type="text"
                    id="wiz-duration"
                    name="rentalDaysDisplay"
                    readonly
                    class="w-full rounded-2xl border border-border bg-bg-surface-alt px-4 py-3 text-sm text-text-muted transition-colors duration-300 focus:outline-none"
                    placeholder="Calculated automatically"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <div>
                  <label id="wizard-name-label" for="wiz-name" class="mb-1 block text-xs font-mono uppercase tracking-wider text-text-muted">Name</label>
                  <input
                    type="text"
                    id="wiz-name"
                    name="name"
                    required
                    class="w-full rounded-2xl border border-border bg-bg-surface-alt px-4 py-3 text-sm text-text-primary placeholder:text-text-muted transition-colors duration-300 focus:border-text-muted focus:outline-none"
                    placeholder="Max Mustermann"
                  />
                </div>
                <div>
                  <label id="wizard-email-label" for="wiz-email" class="mb-1 block text-xs font-mono uppercase tracking-wider text-text-muted">Email</label>
                  <input
                    type="email"
                    id="wiz-email"
                    name="email"
                    required
                    class="w-full rounded-2xl border border-border bg-bg-surface-alt px-4 py-3 text-sm text-text-primary placeholder:text-text-muted transition-colors duration-300 focus:border-text-muted focus:outline-none"
                    placeholder="max@example.com"
                  />
                </div>
              </div>

              <div class="flex-1">
                <label id="wizard-message-label" for="wiz-message" class="mb-1 block text-xs font-mono uppercase tracking-wider text-text-muted">Message</label>
                <textarea
                  id="wiz-message"
                  name="message"
                  rows="4"
                  class="min-h-[120px] w-full resize-none rounded-2xl border border-border bg-bg-surface-alt px-4 py-3 text-sm text-text-primary placeholder:text-text-muted transition-colors duration-300 focus:border-text-muted focus:outline-none"
                  placeholder="Preferred dates, questions, special requests."
                ></textarea>
              </div>

              <button
                id="wizard-submit"
                type="submit"
                class="w-full rounded-2xl bg-accent px-6 py-4 text-sm font-body font-medium uppercase tracking-widest text-text-primary transition-colors duration-300 hover:bg-accent-hover"
              >
                Send request
              </button>
              <p id="wizard-error" class="hidden text-sm font-body text-[#ff8a8a]"></p>
            </form>
          </div>

          <div id="wizard-success" class="hidden py-8 text-center">
            <div id="wizard-confetti" class="pointer-events-none absolute inset-0 overflow-hidden"></div>
            <h3 id="wizard-success-title" class="mb-3 font-display text-2xl">Thank you</h3>
            <p id="wizard-success-copy" class="font-body text-text-secondary">
