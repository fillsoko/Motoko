      brandAny: 'No preference',
      brandAnyCopy: 'Show me the strongest fit',
      modelCopy: 'Choose a motorcycle model so we can tailor the next steps.',
      modelFilterAll: 'All bikes',
      modelFilterBrand: 'Brand: {brand}',
      modelMetaFrom: 'from {price} EUR / day',
      bookingRibeCopy: 'Online platform with Europe-wide fully comprehensive cover',
      bookingDirectCopy: 'Personal contact and individual coordination',
      bookingUnsureCopy: 'Please advise me',
      insuranceFullCopy: 'Maximum protection, included with RIBE bookings',
      insuranceBasicCopy: 'The minimum legal cover',
      insuranceOwnCopy: 'I already have a preferred setup',
      prefillKicker: 'Direct request',
      prefillCopy: 'Direct booking request via motoko. Brand: {brand}. Model: {bike}. Booking route: {booking}.',
      summaryKicker: 'Request preview',
      summaryBullets: {
        interest: 'You are looking for: {value}',
        brand: 'Preferred brand: {value}',
        bike: 'Selected bike: {value}',
        dates: 'Rental dates: {value}',
        duration: 'Duration: {value}',
        booking: 'Preferred booking route: {value}',
        insurance: 'Insurance: {value}',
      },
      dateFromLabel: 'From',
      dateToLabel: 'To',
      durationLabel: 'Days',
      durationPlaceholder: 'Calculated automatically',
      nameLabel: 'Name',
      emailLabel: 'Email',
      messageLabel: 'Message',
      messagePlaceholder: 'Preferred dates, questions, or special requests.',
      namePlaceholder: 'Max Mustermann',
      emailPlaceholder: 'max@example.com',
      autoMessage: 'I am interested in the {bike}. Please get back to me with availability and the next steps.',
      summaryTitle: 'Request for {bike}',
      summaryTitleGeneric: 'New inquiry via motoko.de',
      requestNotReady: 'The inquiry form is not active yet. Please configure EmailJS or contact us directly at {email}.',
      templateMissing: 'The matching email template could not be found. Please contact us directly at {email}.',
      requestFailed: 'The request could not be sent. Please contact us directly at {email}.',
      missingStep: 'Please choose an option first.',
      missingBike: 'Please select a bike model first.',
      invalidDates: 'Please choose a valid date range.',
      bikeSummaryNone: 'Still open',
      datesSummaryNone: 'Still open',
      durationSummaryNone: 'Still open',
      summaryHeading: 'Summary of your request',
    },
  };

  const brandParamMap = {
    bmw: 'bmw',
    buell: 'other',
    ducati: 'ducati',
    'harley-davidson': 'harley',
    harley: 'harley',
    honda: 'honda',
    husqvarna: 'other',
    kawasaki: 'other',
    triumph: 'triumph',
  };

  const emailJsConfigured = Boolean(
    EMAILJS_PUBLIC_KEY &&
      EMAILJS_SERVICE_ID &&
      (EMAILJS_TEMPLATE_ID || EMAILJS_TEMPLATE_ID_DE || EMAILJS_TEMPLATE_ID_EN)
  );

  const wizard = {
    step: 1,
    total: 6,
    lang: 'de',
    data: {},

    init() {
      this.lang = this.getCurrentLanguage();
      this.applyPrefillFromUrl();
      this.bindEvents();
      this.renderLanguage();
      this.renderPrefill();
      this.renderSummary();
      this.render();
    },

    bindEvents() {
      document.querySelectorAll('.wizard-option').forEach((btn) => {
        btn.addEventListener('click', () => {
          const choice = btn.dataset.choice;
          const value = btn.dataset.value;
          if (!choice || !value) return;

          this.clearError();
          this.data[choice] = value;

          if (choice === 'brand') {
            this.syncBikeToBrand();
          }

          setTimeout(() => {
            if (choice === 'brand') {
              this.next();
              this.renderBikeOptions();
              return;
            }

            this.next();
          }, 180);
        });
      });

      const backBtn = document.getElementById('wizard-back');
      if (backBtn) {
        backBtn.addEventListener('click', () => {
          this.prev();
        });
      }

      const wizForm = document.getElementById('wizard-form');
      if (wizForm) {
        wizForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const form = e.target;
          const formData = new FormData(form);
          this.data.rentalFrom = formData.get('rentalFrom');
          this.data.rentalTo = formData.get('rentalTo');
          this.data.rentalDays = this.getRentalDays();
          this.data.name = formData.get('name');
          this.data.email = formData.get('email');
          this.data.message = formData.get('message');
          await this.submit(form);
        });
      }

      const dateFromInput = document.getElementById('wiz-date-from');
      const dateToInput = document.getElementById('wiz-date-to');
      [dateFromInput, dateToInput].forEach((input) => {
        input?.addEventListener('input', () => {
          this.data.rentalFrom = document.getElementById('wiz-date-from')?.value || '';
          this.data.rentalTo = document.getElementById('wiz-date-to')?.value || '';
          this.syncDurationField();
          this.renderSummary();
        });
      });

      document.querySelectorAll('[data-lang-btn]').forEach((button) => {
        button.addEventListener('click', () => {
          window.setTimeout(() => {
            this.lang = this.getCurrentLanguage();
            this.renderLanguage();
            this.renderPrefill();
            this.renderSummary();
            this.render();
          }, 0);
        });
      });

      window.addEventListener('storage', (event) => {
        if (event.key !== 'motoko-lang') return;
        this.lang = this.getCurrentLanguage();
        this.renderLanguage();
        this.renderPrefill();
        this.renderSummary();
        this.render();
      });
    },

    t(key) {
      const locale = translations[this.lang] || translations.de;
      return key.split('.').reduce((value, segment) => value?.[segment], locale);
    },

    format(message, params = {}) {
      return Object.entries(params).reduce((result, [key, value]) => {
        return result.replaceAll(`{${key}}`, value ?? '');
      }, message);
    },

    getCurrentLanguage() {
      const saved = localStorage.getItem('motoko-lang');
      if (saved === 'de' || saved === 'en') return saved;

      const htmlLang = document.documentElement.lang?.toLowerCase();
      if (htmlLang?.startsWith('de')) return 'de';
      if (htmlLang?.startsWith('en')) return 'en';

      return navigator.language?.toLowerCase().startsWith('de') ? 'de' : 'en';
    },

    getTemplateId() {
      if (this.lang === 'de') {
        return EMAILJS_TEMPLATE_ID_DE || EMAILJS_TEMPLATE_ID || EMAILJS_TEMPLATE_ID_EN;
      }

      return EMAILJS_TEMPLATE_ID_EN || EMAILJS_TEMPLATE_ID || EMAILJS_TEMPLATE_ID_DE;
    },

    getLabel(group, value) {
      return optionLabels[group]?.[this.lang]?.[value] || value || '';
    },

    getAvailableBikes() {
      const selectedBrand = this.data.brand;
      if (!selectedBrand || selectedBrand === 'no-preference' || selectedBrand === 'other') {
        return bikesForWizard;
      }

      return bikesForWizard.filter((bike) => bike.brand === selectedBrand);
    },

    getBikeBySlug(slug) {
      return bikesForWizard.find((bike) => bike.slug === slug);
    },

    syncBikeToBrand() {
      if (!this.data.bikeSlug) return;
      const selectedBike = this.getBikeBySlug(this.data.bikeSlug);
      if (!selectedBike) return;

      const selectedBrand = this.data.brand;
      const brandMatches =
        !selectedBrand ||
        selectedBrand === 'no-preference' ||
        selectedBrand === 'other' ||
        selectedBike.brand === selectedBrand;

      if (!brandMatches) {
        this.data.bikeSlug = '';
        this.data.bike = '';
      }
    },

    applyPrefillFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const prefilledBike = params.get('bike');
      if (!prefilledBike) return;

      const prefilledBrand = params.get('brand')?.trim().toLowerCase() || '';
      const prefilledBooking = params.get('booking')?.trim().toLowerCase() || '';
      const prefilledInterest = params.get('interest')?.trim().toLowerCase() || '';
      const mappedBrand = brandParamMap[prefilledBrand] || 'other';

      this.data.bike = prefilledBike;
      this.data.bikeSlug = params.get('bikeSlug') || '';
      this.data.brand = mappedBrand;
      this.data.booking = prefilledBooking === 'motoko' ? 'direct' : (prefilledBooking || 'direct');
      this.data.interest = prefilledInterest || 'bike';
      this.step = 4;
    },

    renderLanguage() {
      document.getElementById('wizard-browser-label').textContent = this.t('browserLabel');
      document.getElementById('wizard-kicker').textContent = this.t('kicker');
      document.getElementById('wizard-title').textContent = this.t('title');
      document.getElementById('wizard-intro').textContent = this.t('intro');

      document.getElementById('step-1-heading').textContent = this.t('headings.step1');
      document.getElementById('step-2-heading').textContent = this.t('headings.step2');
      document.getElementById('step-3-heading').textContent = this.t('headings.step3');
      document.getElementById('step-4-heading').textContent = this.t('headings.step4');
      document.getElementById('step-5-heading').textContent = this.t('headings.step5');
      document.getElementById('step-6-heading').textContent = this.t('headings.step6');
      document.getElementById('step-3-copy').textContent = this.t('modelCopy');

      document.getElementById('interest-bike-label').textContent = this.getLabel('interest', 'bike');
      document.getElementById('interest-bike-copy').textContent = this.t('interestBikeCopy');
      document.getElementById('interest-tour-label').textContent = this.getLabel('interest', 'tour');
      document.getElementById('interest-tour-copy').textContent = this.t('interestTourCopy');
      document.getElementById('interest-both-label').textContent = this.getLabel('interest', 'both');
      document.getElementById('interest-both-copy').textContent = this.t('interestBothCopy');

      document.getElementById('brand-other-label').textContent = this.t('brandOther');
      document.getElementById('brand-any-label').textContent = this.t('brandAny');
      document.getElementById('brand-any-copy').textContent = this.t('brandAnyCopy');

      document.getElementById('booking-ribe-label').textContent = this.getLabel('booking', 'ribe');
      document.getElementById('booking-ribe-copy').textContent = this.t('bookingRibeCopy');
      document.getElementById('booking-direct-label').textContent = this.getLabel('booking', 'direct');
      document.getElementById('booking-direct-copy').textContent = this.t('bookingDirectCopy');
      document.getElementById('booking-unsure-label').textContent = this.getLabel('booking', 'unsure');
      document.getElementById('booking-unsure-copy').textContent = this.t('bookingUnsureCopy');

      document.getElementById('insurance-full-label').textContent = this.getLabel('insurance', 'full');
      document.getElementById('insurance-full-copy').textContent = this.t('insuranceFullCopy');
      document.getElementById('insurance-basic-label').textContent = this.getLabel('insurance', 'basic');
      document.getElementById('insurance-basic-copy').textContent = this.t('insuranceBasicCopy');
      document.getElementById('insurance-own-label').textContent = this.getLabel('insurance', 'own');
      document.getElementById('insurance-own-copy').textContent = this.t('insuranceOwnCopy');

      document.getElementById('wizard-prefill-kicker').textContent = this.t('prefillKicker');
      document.getElementById('wizard-summary-kicker').textContent = this.t('summaryKicker');
      document.getElementById('wizard-date-from-label').textContent = this.t('dateFromLabel');
      document.getElementById('wizard-date-to-label').textContent = this.t('dateToLabel');
      document.getElementById('wizard-duration-label').textContent = this.t('durationLabel');
      document.getElementById('wizard-name-label').textContent = this.t('nameLabel');
      document.getElementById('wizard-email-label').textContent = this.t('emailLabel');
      document.getElementById('wizard-message-label').textContent = this.t('messageLabel');
      document.getElementById('wiz-duration').placeholder = this.t('durationPlaceholder');
      document.getElementById('wiz-name').placeholder = this.t('namePlaceholder');
      document.getElementById('wiz-email').placeholder = this.t('emailPlaceholder');
      document.getElementById('wiz-message').placeholder = this.t('messagePlaceholder');
      document.getElementById('wizard-success-title').textContent = this.t('successTitle');
      document.getElementById('wizard-success-copy').textContent = this.t('successCopy');

      this.renderProgressDots();
      this.renderBikeOptions();
      this.syncDurationField();
      this.renderSummary();
      this.setSubmitting(false);
    },

    renderProgressDots() {
      const container = document.getElementById('step-dots');
      if (!container) return;

      container.innerHTML = '';
      this.t('stepNames').forEach((label, index) => {
        const step = index + 1;
        const item = document.createElement('div');
        item.dataset.dotItem = String(step);
        item.className =
          'wizard-progress-item flex min-w-[170px] items-center gap-3 rounded-2xl border px-3 py-3 transition-colors duration-300 lg:min-w-0';

        item.innerHTML = `
          <div data-dot="${step}" class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border text-xs font-mono transition-colors duration-300">${step}</div>
          <div class="min-w-0">
            <p class="font-body text-sm font-medium text-text-secondary">${label}</p>
          </div>
        `;

        container.appendChild(item);
      });
    },

    renderBikeOptions() {
      const container = document.getElementById('wizard-bike-grid');
      const filter = document.getElementById('wizard-model-filter');
      if (!container || !filter) return;

      const availableBikes = this.getAvailableBikes();
      const selectedBrand = this.data.brand;

      filter.textContent =
        !selectedBrand || selectedBrand === 'no-preference' || selectedBrand === 'other'
          ? this.t('modelFilterAll')
          : this.format(this.t('modelFilterBrand'), { brand: this.getLabel('brand', selectedBrand) });

      container.innerHTML = '';

      availableBikes.forEach((bike) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.dataset.choice = 'bike';
        button.dataset.value = bike.slug;
        button.className =
          'wizard-bike-option flex h-full flex-col rounded-2xl border border-border px-5 py-5 text-left transition-colors duration-300 hover:border-text-muted';

        const isSelected = this.data.bikeSlug === bike.slug;
        if (isSelected) {
          button.classList.add('border-text-primary');
        }

        button.innerHTML = `
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-display text-2xl text-text-primary">${bike.name}</p>
              <p class="mt-2 text-xs font-mono uppercase tracking-[0.2em] text-accent">${this.getLabel('brand', bike.brand) || bike.brand}</p>
            </div>
            <div class="rounded-full border border-white/10 px-3 py-1 text-[11px] font-mono uppercase tracking-[0.2em] text-text-muted">${bike.year}</div>
          </div>
          <div class="mt-5 grid gap-2 text-sm text-text-secondary">
            <p>${bike.category}</p>
            <p>${this.format(this.t('modelMetaFrom'), { price: String(bike.pricePerDay) })}</p>
          </div>
        `;

        button.addEventListener('click', () => {
          this.clearError();
          this.data.bikeSlug = bike.slug;
          this.data.bike = bike.name;
          container.querySelectorAll('.wizard-bike-option').forEach((option) => {
            option.classList.remove('border-text-primary');
          });
          button.classList.add('border-text-primary');
          setTimeout(() => this.next(), 180);
        });

        container.appendChild(button);
      });
    },

    renderPrefill() {
      const container = document.getElementById('wizard-prefill');
      const title = document.getElementById('wizard-prefill-title');
      const copy = document.getElementById('wizard-prefill-copy');
      const message = document.getElementById('wiz-message');
      if (!container || !title || !copy) return;

      if (!this.data.bike) {
        container.classList.add('hidden');
        return;
      }

      container.classList.remove('hidden');
      title.textContent = this.data.bike;
      copy.textContent = this.format(this.t('prefillCopy'), {
        brand: this.getLabel('brand', this.data.brand),
        bike: this.data.bike,
        booking: this.getLabel('booking', this.data.booking),
      });

      if (message && !message.value) {
        message.value = this.format(this.t('autoMessage'), { bike: this.data.bike });
      }
    },

    renderSummary() {
      const summaryList = document.getElementById('wizard-summary-list');
      if (!summaryList) return;

      const bikeLabel = this.data.bike || this.t('bikeSummaryNone');
      const datesLabel =
        this.data.rentalFrom && this.data.rentalTo
          ? `${this.data.rentalFrom} -> ${this.data.rentalTo}`
          : this.t('datesSummaryNone');
      const bulletKeys = [
        ['interest', this.getLabel('interest', this.data.interest)],
        ['brand', this.getLabel('brand', this.data.brand)],
        ['bike', bikeLabel],
        ['dates', datesLabel],
        ['duration', this.getRentalDaysLabel()],
        ['booking', this.getLabel('booking', this.data.booking)],
        ['insurance', this.getLabel('insurance', this.data.insurance)],
      ];

      summaryList.innerHTML = '';

      bulletKeys.forEach(([key, value]) => {
        const item = document.createElement('li');
        item.className = 'flex items-start gap-3 text-sm leading-relaxed text-text-secondary';
        item.innerHTML = `
          <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-accent"></span>
          <span>${this.format(this.t(`summaryBullets.${key}`), { value: value || this.t('bikeSummaryNone') })}</span>
        `;
        summaryList.appendChild(item);
      });
    },

    showError(message) {
      const error = document.getElementById('wizard-error');
      if (!error) return;
      error.textContent = message;
      error.classList.remove('hidden');
    },

    clearError() {
      const error = document.getElementById('wizard-error');
      if (!error) return;
      error.textContent = '';
      error.classList.add('hidden');
    },

    setSubmitting(isSubmitting) {
      const submitButton = document.getElementById('wizard-submit');
      if (!submitButton) return;
      submitButton.toggleAttribute('disabled', isSubmitting);
      submitButton.textContent = isSubmitting ? this.t('submitting') : this.t('submit');
      submitButton.classList.toggle('opacity-60', isSubmitting);
      submitButton.classList.toggle('cursor-not-allowed', isSubmitting);
    },

    getRentalDays() {
      const from = this.data.rentalFrom || document.getElementById('wiz-date-from')?.value;
      const to = this.data.rentalTo || document.getElementById('wiz-date-to')?.value;
      if (!from || !to) return '';

      const fromDate = new Date(`${from}T00:00:00`);
      const toDate = new Date(`${to}T00:00:00`);
      const diff = Math.round((toDate.getTime() - fromDate.getTime()) / 86400000) + 1;
      if (!Number.isFinite(diff) || diff <= 0) return '';
      return String(diff);
    },

    getRentalDaysLabel() {
      const days = this.getRentalDays();
      if (!days) return this.t('durationSummaryNone');
      return this.lang === 'de' ? `${days} Tage` : `${days} days`;
    },

    syncDurationField() {
      const durationField = document.getElementById('wiz-duration');
      if (!durationField) return;

      const days = this.getRentalDays();
      this.data.rentalDays = days;
      durationField.value = days ? this.getRentalDaysLabel() : '';
    },

    validateCurrentStep() {
      if (this.step === 3 && !this.data.bikeSlug) {
        this.showError(this.t('missingBike'));
        return false;
      }

      const requiredKeyByStep = {
        1: 'interest',
        2: 'brand',
        4: 'booking',
        5: 'insurance',
      };

      const requiredKey = requiredKeyByStep[this.step];
      if (requiredKey && !this.data[requiredKey]) {
        this.showError(this.t('missingStep'));
        return false;
      }

      if (this.step === 6) {
        const days = this.getRentalDays();
        if ((this.data.rentalFrom || this.data.rentalTo) && !days) {
          this.showError(this.t('invalidDates'));
          return false;
        }
      }

      return true;
    },

    getSubmissionLanguage() {
      return this.lang === 'de' ? 'de' : 'en';
    },

    async submit(form) {
      this.clearError();
      this.setSubmitting(true);

      if (!emailJsConfigured) {
        this.showError(this.format(this.t('requestNotReady'), { email: RECIPIENT_EMAIL }));
        this.setSubmitting(false);
        return;
      }

      const selectedTemplateId = this.getTemplateId();
      if (!selectedTemplateId) {
        this.showError(this.format(this.t('templateMissing'), { email: RECIPIENT_EMAIL }));
        this.setSubmitting(false);
        return;
      }

      const summaryLines = [
        this.format(this.t('summaryBullets.interest'), { value: this.getLabel('interest', this.data.interest) }),
        this.format(this.t('summaryBullets.brand'), { value: this.getLabel('brand', this.data.brand) }),
        this.format(this.t('summaryBullets.bike'), { value: this.data.bike || this.t('bikeSummaryNone') }),
        this.format(this.t('summaryBullets.dates'), {
          value:
            this.data.rentalFrom && this.data.rentalTo
              ? `${this.data.rentalFrom} -> ${this.data.rentalTo}`
              : this.t('datesSummaryNone'),
        }),
        this.format(this.t('summaryBullets.duration'), { value: this.getRentalDaysLabel() }),
        this.format(this.t('summaryBullets.booking'), { value: this.getLabel('booking', this.data.booking) }),
        this.format(this.t('summaryBullets.insurance'), { value: this.getLabel('insurance', this.data.insurance) }),
      ];

      const title = this.data.bike
        ? this.format(this.t('summaryTitle'), { bike: this.data.bike })
        : this.t('summaryTitleGeneric');

      const bodyParts = [
        this.t('summaryHeading'),
        ...summaryLines.map((line) => `- ${line}`),
        '',
        `${this.t('nameLabel')}: ${this.data.name || ''}`,
        `${this.t('emailLabel')}: ${this.data.email || ''}`,
        '',
        `${this.t('messageLabel')}:`,
        this.data.message || '-',
      ];

      const submittedAt = new Date().toLocaleString(this.lang === 'de' ? 'de-DE' : 'en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
      });

      const templateParams = {
        to_email: RECIPIENT_EMAIL,
        reply_to: this.data.email || '',
        from_name: this.data.name || 'Unknown',
        from_email: this.data.email || '',
        name: this.data.name || '',
        email: this.data.email || '',
        title,
        message: bodyParts.join('\n'),
        submitted_at: submittedAt,
        interest: this.getLabel('interest', this.data.interest),
        brand: this.getLabel('brand', this.data.brand),
        booking: this.getLabel('booking', this.data.booking),
        insurance: this.getLabel('insurance', this.data.insurance),
        bike: this.data.bike || this.t('bikeSummaryNone'),
        bike_slug: this.data.bikeSlug || '',
        rental_from: this.data.rentalFrom || '',
        rental_to: this.data.rentalTo || '',
        rental_days: this.data.rentalDays || '',
        language: this.getSubmissionLanguage(),
      };

      try {
        const response = await fetch(EMAILJS_ENDPOINT, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            service_id: EMAILJS_SERVICE_ID,
            template_id: selectedTemplateId,
            user_id: EMAILJS_PUBLIC_KEY,
            template_params: templateParams,
          }),
        });

        if (!response.ok) {
          const errorText = await response.text();
          throw new Error(errorText || 'EmailJS request failed');
        }

        form.reset();
        this.showSuccess();
      } catch (error) {
        console.error('Submission failed', error);
        this.showError(this.format(this.t('requestFailed'), { email: RECIPIENT_EMAIL }));
      } finally {
        this.setSubmitting(false);
      }
    },

    showSuccess() {
      document.querySelectorAll('.wizard-step').forEach((step) => step.classList.add('hidden'));
      document.getElementById('wizard-success')?.classList.remove('hidden');
      document.getElementById('wizard-nav')?.classList.add('hidden');
      document.getElementById('step-dots')?.classList.add('hidden');
      document.getElementById('step-label')?.classList.add('hidden');
      this.launchConfetti();
    },

    launchConfetti() {
      const container = document.getElementById('wizard-confetti');
      if (!container) return;

      container.innerHTML = '';

      const colors = ['#ff6b00', '#ffffff', '#d9d9d9', '#ffb067'];
      const pieceCount = 24;

      for (let i = 0; i < pieceCount; i += 1) {
        const piece = document.createElement('span');
        piece.className = 'wizard-confetti-piece';
        piece.style.left = `${Math.random() * 100}%`;
        piece.style.backgroundColor = colors[i % colors.length];
        piece.style.animationDelay = `${Math.random() * 180}ms`;
        piece.style.setProperty('--confetti-x', `${Math.round((Math.random() - 0.5) * 180)}px`);
        piece.style.setProperty('--confetti-rotate', `${Math.round((Math.random() - 0.5) * 520)}deg`);
        container.appendChild(piece);
      }

      window.setTimeout(() => {
        container.innerHTML = '';
      }, 1800);
    },

    next() {
      if (!this.validateCurrentStep()) return;
      if (this.step >= this.total) return;
      this.step++;
      if (this.step === 3) {
        this.renderBikeOptions();
      }
      if (this.step === 6) {
        this.renderSummary();
        this.renderPrefill();
      }
      this.render();
    },

    prev() {
      if (this.step <= 1) return;
      this.step--;
      this.clearError();
      this.render();
    },

    render() {
      document.querySelectorAll('.wizard-step').forEach((step) => {
        step.classList.add('hidden');
        step.classList.remove('flex');
      });

      const active = document.querySelector(`[data-step="${this.step}"]`);
      if (active) {
        active.classList.remove('hidden');
        active.classList.add('flex');
      }

      document.querySelectorAll('.wizard-option').forEach((option) => {
        const group = option.dataset.choice;
        const value = option.dataset.value;
        const isSelected =
          (group === 'bike' && this.data.bikeSlug === value) ||
          (group && group !== 'bike' && this.data[group] === value);
        option.classList.toggle('border-text-primary', Boolean(isSelected));
      });

      document.querySelectorAll('[data-dot]').forEach((dot) => {
        const n = parseInt(dot.dataset.dot, 10);
        dot.classList.toggle('border-accent', n <= this.step);
        dot.classList.toggle('bg-accent', n <= this.step);
        dot.classList.toggle('text-black', n <= this.step);
        dot.classList.toggle('border-white/10', n > this.step);
        dot.classList.toggle('text-text-muted', n > this.step);
      });

      document.querySelectorAll('[data-dot-item]').forEach((item) => {
        const n = parseInt(item.dataset.dotItem, 10);
        item.classList.toggle('border-accent/40', n <= this.step);
        item.classList.toggle('bg-accent-muted/30', n <= this.step);
        item.classList.toggle('border-white/10', n > this.step);
        item.classList.toggle('bg-white/[0.03]', n > this.step);
      });

      const label = document.getElementById('step-label');
      if (label) {
        label.textContent = this.format(this.t('stepCounter'), {
          step: String(this.step),
          total: String(this.total),
        });
      }

      const back = document.getElementById('wizard-back');
      if (back) {
        back.classList.toggle('invisible', this.step === 1);
        back.textContent = this.t('back');
      }
    },
  };

  wizard.init();
</script>
