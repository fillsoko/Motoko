---
import { partners } from '../data/partners';
---

<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="mb-12 reveal">
      <span class="text-xs font-mono uppercase tracking-widest text-accent"
        data-i18n-de="Netzwerk"
        data-i18n-en="Network"
      >Netzwerk</span>
      <h2 class="font-display text-4xl md:text-5xl font-normal mb-4 mt-2"
        data-i18n-de="Partner"
        data-i18n-en="Partners"
      >Partner</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal">
      {partners.map((partner) => (
        <a
          href={partner.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group bg-bg-surface border border-border rounded-lg p-6 hover:border-text-muted transition-colors duration-300"
        >
          <div class="flex items-center justify-between mb-3">
            <h3 class="font-display text-lg font-normal group-hover:text-accent transition-colors duration-300">
              {partner.name}
            </h3>
            <span class="text-xs font-mono uppercase tracking-wider text-text-muted">{partner.category}</span>
          </div>
          <p class="font-body text-text-secondary text-sm leading-relaxed"
            data-i18n-de={partner.descDe}
            data-i18n-en={partner.descEn}
          >{partner.descDe}</p>
          <span class="inline-flex items-center gap-1 mt-4 text-xs font-mono text-text-muted group-hover:text-accent transition-colors duration-300">
            <span data-i18n-de="Besuchen" data-i18n-en="Visit">Besuchen</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
