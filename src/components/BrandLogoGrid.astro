---
import { brands } from '../data/brands';
---

<div class="hero-logo-marquee">
  <div class="hero-logo-marquee-track">
    {[0, 1].map((copy) => (
      <div class="hero-logo-marquee-group" aria-hidden={copy === 1 ? 'true' : 'false'}>
        {brands.map((brand) => (
          <div class="hero-logo-marquee-item">
            <img
              src={brand.logo}
              alt={copy === 0 ? brand.name : ''}
              class:list={[
                'h-7 w-auto max-w-[82px] object-contain opacity-78 sm:h-8 sm:max-w-[94px] md:h-9 md:max-w-[106px]',
                brand.name === 'Harley-Davidson' && 'scale-[1.3]',
                !brand.preserveColor && 'brightness-0 invert',
              ]}
              loading="lazy"
            />
          </div>
        ))}
      </div>
    ))}
  </div>
</div>

<style is:global>
  .hero-logo-marquee {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 1.25rem 0;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  @media (min-width: 640px) {
    .hero-logo-marquee {
      padding: 1.5rem 0;
    }
  }

  .hero-logo-marquee-track {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: hero-logo-scroll 28s linear infinite !important;
    animation-duration: 28s !important;
    animation-iteration-count: infinite !important;
  }

  .hero-logo-marquee-group {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 1.5rem;
    padding-right: 1.5rem;
  }

  @media (min-width: 640px) {
    .hero-logo-marquee-group {
      gap: 2rem;
      padding-right: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-logo-marquee-group {
      gap: 2.5rem;
      padding-right: 2.5rem;
    }
  }

  .hero-logo-marquee-item {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 76px;
    min-width: 102px;
    padding: 1rem;
  }

  @media (min-width: 640px) {
    .hero-logo-marquee-item {
      min-width: 122px;
      padding: 1rem 1.25rem;
    }
  }

  @media (min-width: 768px) {
    .hero-logo-marquee-item {
      min-width: 136px;
      padding: 1rem 1.5rem;
    }
  }

  @keyframes hero-logo-scroll {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

</style>
