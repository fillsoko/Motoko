---
import { Image } from 'astro:assets';
import FadeIn from './motion/FadeIn';
import StaggerContainer from './motion/StaggerContainer';
import StaggerItem from './motion/StaggerItem';
import bgImage from '../assets/images/sections/why-frankfurt-bg.webp';

const reasons = [
  {
    titleDe: 'Zentrales Europa',
    titleEn: 'Central Europe',
    descDe: 'Frankfurt liegt im Herzen Europas — Autobahnnetz in alle Richtungen, Alpen in 3 Stunden, Nordsee in 4.',
    descEn: 'Frankfurt sits at the heart of Europe — motorway network in every direction, Alps in 3 hours, North Sea in 4.',
    icon: 'compass',
  },
  {
    titleDe: 'Legendäre Regionen',
    titleEn: 'Legendary Regions',
    descDe: 'Taunus, Odenwald, Schwarzwald, Mosel, Eifel und Nürburgring — alles ab Frankfurt erreichbar.',
    descEn: 'Taunus, Odenwald, Black Forest, Moselle, Eifel and Nürburgring — all reachable from Frankfurt.',
    icon: 'mountain',
  },
  {
    titleDe: 'Internationaler Hub',
    titleEn: 'International Hub',
    descDe: 'Frankfurter Flughafen, ICE-Knotenpunkt und Autoverleih vor Ort. Ideal für internationale Motorradreisende.',
    descEn: 'Frankfurt Airport, ICE rail hub and car rentals on-site. Ideal for international motorcycle travelers.',
    icon: 'plane',
  },
];
---

<section class="relative py-24 px-6 overflow-hidden bg-[#222222]">
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={bgImage}
      alt=""
      class="w-full h-full object-cover grayscale opacity-40"
      widths={[800, 1200, 1920]}
      sizes="100vw"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#303030]/92 via-[#222222]/58 to-[#141414]"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <FadeIn client:visible direction="up">
      <div class="mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-accent"
          data-i18n-de="Standort"
          data-i18n-en="Location"
        >Standort</span>
        <h2 class="font-display text-4xl md:text-5xl font-normal mb-4 mt-2"
          data-i18n-de="Warum Frankfurt"
          data-i18n-en="Why Frankfurt"
        >Warum Frankfurt</h2>
      </div>
    </FadeIn>

    <StaggerContainer client:visible className="grid grid-cols-1 gap-5 md:grid-cols-3 md:gap-6">
      {reasons.map((reason) => (
        <StaggerItem client:visible>
          <div class="h-full rounded-2xl border border-border bg-bg-surface/80 p-6 text-center backdrop-blur-sm transition-colors duration-300 hover:border-text-muted md:p-7 md:text-left">
            <div class="mb-6 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-accent-muted md:h-12 md:w-12">
              {reason.icon === 'compass' && (
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
              )}
              {reason.icon === 'mountain' && (
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 20l4.5-9 3.5 5 4-7 4 11H4z" />
                </svg>
              )}
              {reason.icon === 'plane' && (
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              )}
            </div>
            <h3 class="font-display text-xl font-normal mb-3"
              data-i18n-de={reason.titleDe}
              data-i18n-en={reason.titleEn}
            >{reason.titleDe}</h3>
            <p class="font-body text-text-secondary text-sm leading-relaxed"
              data-i18n-de={reason.descDe}
              data-i18n-en={reason.descEn}
            >{reason.descDe}</p>
          </div>
        </StaggerItem>
      ))}
    </StaggerContainer>
  </div>
</section>
