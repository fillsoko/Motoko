---
import type { Post } from '../data/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;

const formattedDate = new Date(post.date).toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group bg-bg-surface border border-border rounded-lg overflow-hidden hover:border-text-muted transition-colors duration-300">
  <a href={`/journal/${post.slug}`} class="block">
    <div class="aspect-[3/2] bg-bg-surface-alt"></div>
    <div class="p-6">
      <div class="flex items-center gap-3 mb-3">
        <span class="inline-block px-2 py-0.5 text-xs font-mono uppercase tracking-wider text-text-muted border border-accent-muted rounded"
          data-i18n-de={post.category}
          data-i18n-en={post.categoryEn}
        >{post.category}</span>
        <span class="text-xs font-mono text-text-muted">{post.readingTime}</span>
      </div>
      <h3 class="font-display text-xl font-normal mb-3 group-hover:text-accent transition-colors duration-300"
        data-i18n-de={post.titleDe}
        data-i18n-en={post.titleEn}
      >{post.titleDe}</h3>
      <p class="font-body text-text-secondary text-sm leading-relaxed mb-4"
        data-i18n-de={post.excerptDe}
        data-i18n-en={post.excerptEn}
      >{post.excerptDe}</p>
      <time class="font-mono text-xs text-text-muted">{formattedDate}</time>
    </div>
  </a>
</article>
