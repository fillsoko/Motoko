<button
  type="button"
  class="scroll-cue group absolute bottom-8 left-1/2 z-20 flex h-12 w-12 -translate-x-1/2 items-center justify-center rounded-full border border-white/20 bg-black/20 text-text-primary backdrop-blur-sm transition-colors duration-300 hover:border-white/35 hover:bg-black/30"
  aria-label="Scroll down"
>
  <span class="sr-only">Scroll down</span>
  <svg
    viewBox="0 0 24 24"
    aria-hidden="true"
    class="h-5 w-5 transition-transform duration-300 group-hover:translate-y-0.5"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="1.8"
  >
    <path d="M12 6v11" />
    <path d="m7 13 5 5 5-5" />
  </svg>
</button>

<script>
  document.querySelectorAll('.scroll-cue').forEach((button) => {
    button.addEventListener('click', () => {
      window.scrollBy({ top: window.innerHeight * 0.72, behavior: 'smooth' });
    });
  });
</script>

<style>
  .scroll-cue {
    animation: scroll-cue-pulse 2.6s ease-in-out infinite;
  }

  @keyframes scroll-cue-pulse {
    0%,
    100% {
      transform: translateX(-50%) translateY(0) scale(1);
      box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.12);
      opacity: 0.82;
    }

    50% {
      transform: translateX(-50%) translateY(6px) scale(1.05);
      box-shadow: 0 0 0 12px rgba(255, 255, 255, 0);
      opacity: 1;
    }
  }
 </style>
