---
import { Image } from 'astro:assets';
import FadeIn from './motion/FadeIn';
import bgImage from '../assets/images/sections/instagram-bg.webp';
import bmwGsImage from '../assets/images/bikes/bmw-r-1200-gs/hero.webp';
import rocketImage from '../assets/images/bikes/triumph-rocket-3r/hero.webp';
import ducatiImage from '../assets/images/bikes/ducati-900-ss/hero.webp';
import husqvarnaImage from '../assets/images/bikes/husqvarna-vitpilen-701/hero.webp';
import homeHeroImage from '../assets/images/heroes/home.webp';
import toursHeroImage from '../assets/images/heroes/tours.webp';

const mockPosts = [
  {
    image: bmwGsImage,
    alt: 'BMW R 1200 GS in the motoko fleet',
    label: 'Ride Report',
    caption: 'Taunus morning run on the GS.',
  },
  {
    image: rocketImage,
    alt: 'Triumph Rocket 3 R in the motoko fleet',
    label: 'Bike Portrait',
    caption: 'Torque for days. Rocket 3 R.',
  },
  {
    image: ducatiImage,
    alt: 'Ducati 900 SS in the motoko fleet',
    label: 'Workshop',
    caption: 'Classic Ducati lines, stripped back.',
  },
  {
    image: husqvarnaImage,
    alt: 'Husqvarna Vitpilen 701 in the motoko fleet',
    label: 'City Ride',
    caption: 'Vitpilen detail for Frankfurt streets.',
  },
  {
    image: homeHeroImage,
    alt: 'motoko homepage visual',
    label: 'Behind The Scenes',
    caption: 'From the brand world to the road.',
  },
  {
    image: toursHeroImage,
    alt: 'motoko tours visual',
    label: 'Tour Teaser',
    caption: 'Curated routes out of Frankfurt.',
  },
];
---

<section class="relative py-24 px-6 overflow-hidden bg-[#1d1d1d]">
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={bgImage}
      alt=""
      class="w-full h-full object-cover grayscale opacity-40"
      widths={[800, 1200, 1920]}
      sizes="100vw"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#2a2a2a] via-[#1d1d1d]/60 to-[#121212]"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <FadeIn client:visible direction="up">
      <div class="mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-accent">Instagram</span>
        <h2 class="font-display text-4xl md:text-5xl font-normal mb-4 mt-2">@motoko.ffm</h2>
        <p class="font-body text-text-secondary text-lg"
          data-i18n-de="Folge uns für Tourenberichte, Bike-Portraits und Behind-the-Scenes."
          data-i18n-en="Follow us for ride reports, bike portraits and behind-the-scenes."
        >Folge uns für Tourenberichte, Bike-Portraits und Behind-the-Scenes.</p>
      </div>
    </FadeIn>

    <FadeIn client:visible direction="up" delay={0.15}>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {mockPosts.map((post) => (
          <a
            href="https://instagram.com/motoko"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative aspect-square rounded-lg overflow-hidden border border-border hover:border-text-muted transition-colors duration-300"
          >
            <Image
              src={post.image}
              alt={post.alt}
              class="h-full w-full object-cover grayscale transition duration-500 group-hover:scale-[1.04] group-hover:grayscale-0"
              widths={[300, 500]}
              sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 16vw"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-3">
              <p class="font-mono text-[10px] uppercase tracking-[0.28em] text-accent">{post.label}</p>
              <p class="mt-2 font-body text-xs leading-relaxed text-text-primary">{post.caption}</p>
            </div>
          </a>
        ))}
      </div>
    </FadeIn>

    <FadeIn client:visible direction="up" delay={0.25}>
      <div class="mt-8 text-center">
        <a
          href="https://instagram.com/motoko"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 border border-border text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300"
          data-i18n-de="Auf Instagram folgen"
          data-i18n-en="Follow on Instagram"
        >Auf Instagram folgen</a>
      </div>
    </FadeIn>
  </div>
</section>
