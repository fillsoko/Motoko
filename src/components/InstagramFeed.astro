---
import { Image } from 'astro:assets';
import FadeIn from './motion/FadeIn';
import bgImage from '../assets/images/sections/instagram-bg.webp';

const placeholders = Array.from({ length: 6 }, (_, i) => i);
---

<section class="relative py-24 px-6 overflow-hidden">
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={bgImage}
      alt=""
      class="w-full h-full object-cover grayscale opacity-10"
      widths={[800, 1200, 1920]}
      sizes="100vw"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-bg-primary/85 to-bg-primary"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <FadeIn client:visible direction="up">
      <div class="mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-accent">Instagram</span>
        <h2 class="font-display text-4xl md:text-5xl font-normal mb-4 mt-2">@motoko.ffm</h2>
        <p class="font-body text-text-secondary text-lg"
          data-i18n-de="Folge uns für Tourenberichte, Bike-Portraits und Behind-the-Scenes."
          data-i18n-en="Follow us for ride reports, bike portraits and behind-the-scenes."
        >Folge uns für Tourenberichte, Bike-Portraits und Behind-the-Scenes.</p>
      </div>
    </FadeIn>

    <FadeIn client:visible direction="up" delay={0.15}>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {placeholders.map(() => (
          <a
            href="https://instagram.com/motoko"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative aspect-square bg-bg-surface-alt rounded-lg overflow-hidden border border-border hover:border-text-muted transition-colors duration-300"
          >
            <div class="absolute inset-0 flex items-center justify-center opacity-30 group-hover:opacity-60 transition-opacity duration-300">
              <svg class="w-8 h-8 text-text-muted" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </FadeIn>

    <FadeIn client:visible direction="up" delay={0.25}>
      <div class="mt-8 text-center">
        <a
          href="https://instagram.com/motoko"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 border border-border text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300"
          data-i18n-de="Auf Instagram folgen"
          data-i18n-en="Follow on Instagram"
        >Auf Instagram folgen</a>
      </div>
    </FadeIn>
  </div>
</section>
