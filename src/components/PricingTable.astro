---
import { bikes } from '../data/bikes';
import FadeIn from './motion/FadeIn';

const sortedBikes = [...bikes].sort((a, b) => a.pricePerDay - b.pricePerDay);

function getBrandLogo(name: string) {
  const normalized = name.toLowerCase();

  if (normalized.startsWith('bmw')) return '/images/logos/bmw.svg';
  if (normalized.startsWith('buell')) return '/images/logos/buell.svg';
  if (normalized.startsWith('ducati')) return '/images/logos/ducati.svg';
  if (normalized.startsWith('harley-davidson')) return '/images/logos/harley-davidson.svg';
  if (normalized.startsWith('honda')) return '/images/logos/honda.svg';
  if (normalized.startsWith('husqvarna')) return '/images/logos/husqvarna.svg';
  if (normalized.startsWith('kawasaki')) return '/images/logos/kawasaki.svg';
  if (normalized.startsWith('triumph')) return '/images/logos/triumph.svg';

  return null;
}
---

<section class="bg-[#080808] px-4 py-20 sm:px-6 md:py-24">
  <div class="max-w-6xl mx-auto">
    <FadeIn client:visible direction="up">
      <div class="mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-accent"
          data-i18n-de="Übersicht"
          data-i18n-en="Overview"
        >Übersicht</span>
        <h2 class="font-display text-4xl md:text-5xl font-normal mb-4 mt-2"
          data-i18n-de="Preise auf einen Blick"
          data-i18n-en="Pricing at a Glance"
        >Preise auf einen Blick</h2>
        <p class="font-body text-text-secondary text-lg max-w-2xl"
          data-i18n-de="Alle Preise pro Tag inklusive Vollkaskoversicherung. Ab 7 Tagen Mietdauer gelten reduzierte Tarife."
          data-i18n-en="All prices per day including comprehensive insurance. Reduced rates apply for rentals of 7 days or more."
        >Alle Preise pro Tag inklusive Vollkaskoversicherung. Ab 7 Tagen Mietdauer gelten reduzierte Tarife.</p>
      </div>
    </FadeIn>

    <!-- Desktop table -->
    <FadeIn client:visible direction="up" delay={0.15}>
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-border">
              <th class="py-4 pr-4 font-mono text-xs uppercase tracking-wider text-text-muted">Bike</th>
              <th class="py-4 px-4 font-mono text-xs uppercase tracking-wider text-text-muted"
                data-i18n-de="Kategorie"
                data-i18n-en="Category"
              >Kategorie</th>
              <th class="py-4 px-4 font-mono text-xs uppercase tracking-wider text-text-muted">Motor</th>
              <th class="py-4 px-4 font-mono text-xs uppercase tracking-wider text-text-muted text-right"
                data-i18n-de="1 Tag"
                data-i18n-en="1 Day"
              >1 Tag</th>
              <th class="py-4 px-4 font-mono text-xs uppercase tracking-wider text-text-muted text-right"
                data-i18n-de="3 Tage"
                data-i18n-en="3 Days"
              >3 Tage</th>
              <th class="py-4 px-4 font-mono text-xs uppercase tracking-wider text-text-muted text-right"
                data-i18n-de="7 Tage"
                data-i18n-en="7 Days"
              >7 Tage</th>
              <th class="py-4 pl-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border-subtle">
            {sortedBikes.map((bike) => {
              const threeDay = Math.round(bike.pricePerDay * 3 * 0.9);
              const sevenDay = Math.round(bike.pricePerDay * 7 * 0.8);
              const brandLogo = getBrandLogo(bike.name);
              return (
                <tr class="hover:bg-bg-surface transition-colors duration-200">
                  <td class="py-4 pr-4">
                    <a href={`/bikes/${bike.slug}`} class="flex items-center gap-3 font-body text-text-primary hover:text-accent transition-colors duration-300">
                      {brandLogo && (
                        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded border border-border-subtle bg-bg-surface-alt">
                          <img
                            src={brandLogo}
                            alt=""
                            class="h-7 w-7 object-contain brightness-0 invert opacity-80"
                            loading="lazy"
                          />
                        </span>
                      )}
                      <span>{bike.name}</span>
                    </a>
                  </td>
                  <td class="py-4 px-4">
                    <span class="inline-flex min-w-[7.5rem] justify-center px-2 py-0.5 text-xs font-mono uppercase tracking-wider text-text-muted border border-accent-muted rounded">
                      {bike.category}
                    </span>
                  </td>
                  <td class="py-4 px-4 font-body text-text-secondary text-sm">{bike.engine}</td>
                  <td class="py-4 px-4 font-mono text-accent text-right">{bike.pricePerDay} €</td>
                  <td class="py-4 px-4 font-mono text-text-secondary text-right">{threeDay} €</td>
                  <td class="py-4 px-4 font-mono text-text-secondary text-right">{sevenDay} €</td>
                  <td class="py-4 pl-4 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <a
                        href={bike.ripeUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-block px-3 py-2 text-xs font-body font-medium uppercase tracking-widest border border-border rounded hover:bg-accent hover:border-accent hover:text-text-primary transition-colors duration-300 whitespace-nowrap"
                      >Via RIBE</a>
                      <a
                        href={`/#contact?bike=${encodeURIComponent(bike.name)}&brand=${encodeURIComponent(bike.name.split(' ')[0])}&booking=motoko&interest=bike&bikeSlug=${bike.slug}`}
                        class="inline-block px-3 py-2 text-xs font-body font-medium uppercase tracking-widest bg-accent text-text-primary border border-accent rounded hover:bg-accent-hover hover:border-accent-hover transition-colors duration-300 whitespace-nowrap"
                      >Direkt</a>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </FadeIn>

    <!-- Mobile cards -->
    <FadeIn client:visible direction="up" delay={0.15}>
      <div class="md:hidden space-y-4">
        {sortedBikes.map((bike) => {
          const threeDay = Math.round(bike.pricePerDay * 3 * 0.9);
          const sevenDay = Math.round(bike.pricePerDay * 7 * 0.8);
          const brandLogo = getBrandLogo(bike.name);
          return (
            <div class="bg-bg-surface border border-border rounded-lg p-4 sm:p-5">
              <div class="mb-3 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <a href={`/bikes/${bike.slug}`} class="flex items-start gap-3 font-body text-text-primary font-medium hover:text-accent transition-colors duration-300">
                  {brandLogo && (
                    <span class="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded border border-border-subtle bg-bg-surface-alt">
                      <img
                        src={brandLogo}
                        alt=""
                        class="h-7 w-7 object-contain brightness-0 invert opacity-80"
                        loading="lazy"
                      />
                    </span>
                  )}
                  <span>{bike.name}</span>
                </a>
                <span class="inline-flex min-w-[6.5rem] justify-center self-start px-2 py-0.5 text-xs font-mono uppercase tracking-wider text-text-muted border border-accent-muted rounded shrink-0 sm:min-w-[7.5rem]">
                  {bike.category}
                </span>
              </div>
              <p class="font-body text-text-secondary text-sm mb-4">{bike.engine}</p>
              <div class="grid grid-cols-3 gap-3 mb-4">
                <div>
                  <span class="block font-mono text-xs text-text-muted mb-1"
                    data-i18n-de="1 Tag"
                    data-i18n-en="1 Day"
                  >1 Tag</span>
                  <span class="font-mono text-accent">{bike.pricePerDay} €</span>
                </div>
                <div>
                  <span class="block font-mono text-xs text-text-muted mb-1"
                    data-i18n-de="3 Tage"
                    data-i18n-en="3 Days"
                  >3 Tage</span>
                  <span class="font-mono text-text-secondary">{threeDay} €</span>
                </div>
                <div>
                  <span class="block font-mono text-xs text-text-muted mb-1"
                    data-i18n-de="7 Tage"
                    data-i18n-en="7 Days"
                  >7 Tage</span>
                  <span class="font-mono text-text-secondary">{sevenDay} €</span>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-2">
                <a
                  href={bike.ripeUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block text-center px-4 py-2 text-xs font-body font-medium uppercase tracking-widest border border-border rounded hover:bg-accent hover:border-accent transition-colors duration-300"
                >Via RIBE</a>
                <a
                  href={`/#contact?bike=${encodeURIComponent(bike.name)}&brand=${encodeURIComponent(bike.name.split(' ')[0])}&booking=motoko&interest=bike&bikeSlug=${bike.slug}`}
                  class="block text-center px-4 py-2 text-xs font-body font-medium uppercase tracking-widest bg-accent text-text-primary border border-accent rounded hover:bg-accent-hover hover:border-accent-hover transition-colors duration-300"
                >Direkt</a>
              </div>
            </div>
          );
        })}
      </div>
    </FadeIn>
  </div>
</section>
