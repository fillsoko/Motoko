---
import { bikes } from '../data/bikes';
import FadeIn from './motion/FadeIn';

const sortedBikes = [...bikes].sort((a, b) => a.pricePerDay - b.pricePerDay);
---

<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <FadeIn client:visible direction="up">
      <div class="mb-12">
        <span class="text-xs font-mono uppercase tracking-widest text-accent"
          data-i18n-de="Übersicht"
          data-i18n-en="Overview"
        >Übersicht</span>
        <h2 class="font-display text-4xl md:text-5xl font-normal mb-4 mt-2"
          data-i18n-de="Preise auf einen Blick"
          data-i18n-en="Pricing at a Glance"
        >Preise auf einen Blick</h2>
        <p class="font-body text-text-secondary text-lg max-w-2xl"
          data-i18n-de="Alle Preise pro Tag inklusive Vollkaskoversicherung. Ab 7 Tagen Mietdauer gelten reduzierte Tarife."
          data-i18n-en="All prices per day including comprehensive insurance. Reduced rates apply for rentals of 7 days or more."
        >Alle Preise pro Tag inklusive Vollkaskoversicherung. Ab 7 Tagen Mietdauer gelten reduzierte Tarife.</p>
      </div>
    </FadeIn>

    <!-- Desktop table -->
    <FadeIn client:visible direction="up" delay={0.15}>
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-border">
              <th class="py-4 pr-4 font-mono text-xs uppercase tracking-wider text-text-muted">Bike</th>
              <th class="py-4 px-4 font-mono text-xs uppercase tracking-wider text-text-muted"
                data-i18n-de="Kategorie"
                data-i18n-en="Category"
              >Kategorie</th>
              <th class="py-4 px-4 font-mono text-xs uppercase tracking-wider text-text-muted">Motor</th>
              <th class="py-4 px-4 font-mono text-xs uppercase tracking-wider text-text-muted text-right"
                data-i18n-de="1 Tag"
                data-i18n-en="1 Day"
              >1 Tag</th>
              <th class="py-4 px-4 font-mono text-xs uppercase tracking-wider text-text-muted text-right"
                data-i18n-de="3 Tage"
                data-i18n-en="3 Days"
              >3 Tage</th>
              <th class="py-4 px-4 font-mono text-xs uppercase tracking-wider text-text-muted text-right"
                data-i18n-de="7 Tage"
                data-i18n-en="7 Days"
              >7 Tage</th>
              <th class="py-4 pl-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border-subtle">
            {sortedBikes.map((bike) => {
              const threeDay = Math.round(bike.pricePerDay * 3 * 0.9);
              const sevenDay = Math.round(bike.pricePerDay * 7 * 0.8);
              return (
                <tr class="hover:bg-bg-surface transition-colors duration-200">
                  <td class="py-4 pr-4">
                    <a href={`/bikes/${bike.slug}`} class="font-body text-text-primary hover:text-accent transition-colors duration-300">
                      {bike.name}
                    </a>
                  </td>
                  <td class="py-4 px-4">
                    <span class="inline-block px-2 py-0.5 text-xs font-mono uppercase tracking-wider text-text-muted border border-accent-muted rounded">
                      {bike.category}
                    </span>
                  </td>
                  <td class="py-4 px-4 font-body text-text-secondary text-sm">{bike.engine}</td>
                  <td class="py-4 px-4 font-mono text-accent text-right">{bike.pricePerDay} €</td>
                  <td class="py-4 px-4 font-mono text-text-secondary text-right">{threeDay} €</td>
                  <td class="py-4 px-4 font-mono text-text-secondary text-right">{sevenDay} €</td>
                  <td class="py-4 pl-4 text-right">
                    <a
                      href={bike.ripeUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-block px-4 py-2 text-xs font-body font-medium uppercase tracking-widest border border-border rounded hover:bg-accent hover:border-accent hover:text-text-primary transition-colors duration-300"
                      data-i18n-de="Buchen"
                      data-i18n-en="Book"
                    >Buchen</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </FadeIn>

    <!-- Mobile cards -->
    <FadeIn client:visible direction="up" delay={0.15}>
      <div class="md:hidden space-y-4">
        {sortedBikes.map((bike) => {
          const threeDay = Math.round(bike.pricePerDay * 3 * 0.9);
          const sevenDay = Math.round(bike.pricePerDay * 7 * 0.8);
          return (
            <div class="bg-bg-surface border border-border rounded-lg p-5">
              <div class="flex items-start justify-between mb-3">
                <a href={`/bikes/${bike.slug}`} class="font-body text-text-primary font-medium hover:text-accent transition-colors duration-300">
                  {bike.name}
                </a>
                <span class="inline-block px-2 py-0.5 text-xs font-mono uppercase tracking-wider text-text-muted border border-accent-muted rounded shrink-0 ml-2">
                  {bike.category}
                </span>
              </div>
              <p class="font-body text-text-secondary text-sm mb-4">{bike.engine}</p>
              <div class="grid grid-cols-3 gap-3 mb-4">
                <div>
                  <span class="block font-mono text-xs text-text-muted mb-1"
                    data-i18n-de="1 Tag"
                    data-i18n-en="1 Day"
                  >1 Tag</span>
                  <span class="font-mono text-accent">{bike.pricePerDay} €</span>
                </div>
                <div>
                  <span class="block font-mono text-xs text-text-muted mb-1"
                    data-i18n-de="3 Tage"
                    data-i18n-en="3 Days"
                  >3 Tage</span>
                  <span class="font-mono text-text-secondary">{threeDay} €</span>
                </div>
                <div>
                  <span class="block font-mono text-xs text-text-muted mb-1"
                    data-i18n-de="7 Tage"
                    data-i18n-en="7 Days"
                  >7 Tage</span>
                  <span class="font-mono text-text-secondary">{sevenDay} €</span>
                </div>
              </div>
              <a
                href={bike.ripeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="block text-center px-4 py-2 text-xs font-body font-medium uppercase tracking-widest border border-border rounded hover:bg-accent hover:border-accent transition-colors duration-300"
                data-i18n-de="Buchen"
                data-i18n-en="Book"
              >Buchen</a>
            </div>
          );
        })}
      </div>
    </FadeIn>
  </div>
</section>
