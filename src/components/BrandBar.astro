---
const brands = [
  { name: 'BMW', logo: '/images/logos/bmw.png' },
  { name: 'Honda', logo: '/images/logos/honda.svg' },
  { name: 'Triumph', logo: '/images/logos/triumph.svg' },
  { name: 'Ducati', logo: '/images/logos/ducati.svg' },
  { name: 'Buell', logo: '/images/logos/buell.svg' },
  { name: 'Kawasaki', logo: '/images/logos/kawasaki.svg' },
  { name: 'Husqvarna', logo: '/images/logos/husqvarna.svg' },
];
---

<div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
  {brands.map((brand) =>
    brand.logo ? (
      <div class="flex items-center justify-center h-8 opacity-40 hover:opacity-70 transition-opacity duration-300" title={brand.name}>
        <img
          src={brand.logo}
          alt={brand.name}
          class="h-full w-auto max-w-[120px] object-contain brightness-0 invert"
          loading="lazy"
        />
      </div>
    ) : (
      <span class="font-display text-sm font-light tracking-wider text-text-muted hover:text-text-secondary transition-colors duration-300 uppercase" title={brand.name}>
        {brand.name}
      </span>
    )
  )}
</div>
