---
import { brands } from '../data/brands';
---

<div class="flex flex-wrap items-center justify-center gap-6 sm:gap-8 md:gap-10 lg:gap-12 py-2">
  {brands.map((brand) => (
    <button
      type="button"
      class="flex h-8 shrink-0 items-center justify-center opacity-50 transition-opacity duration-300 hover:opacity-80"
      title={brand.name}
      data-brand={brand.name}
      aria-label={`Filter by ${brand.name}`}
    >
      <img
        src={brand.logo}
        alt={brand.name}
        class:list={[
          'h-full w-auto max-w-[80px] sm:max-w-[100px] md:max-w-[120px] object-contain',
          !brand.preserveColor && 'brightness-0 invert',
        ]}
        loading="lazy"
      />
    </button>
  ))}
</div>

<script>
  document.querySelectorAll('[data-brand]').forEach((item) => {
    item.addEventListener('click', () => {
      const brand = item.getAttribute('data-brand');
      if (!brand) return;

      window.dispatchEvent(
        new CustomEvent('fleet:filter-brand', {
          detail: { brand },
        })
      );
    });
  });
</script>
