---
import { Image } from 'astro:assets';
import type { Bike } from '../data/bikes';

interface Props {
  bike: Bike;
}

const { bike } = Astro.props;

// Dynamically load bike images
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/bikes/**/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

// Find first image matching this bike's slug
const bikeImages = Object.entries(allImages)
  .filter(([path]) => path.includes(`/${bike.slug}/`))
  .map(([, mod]) => mod.default);

const heroImage = bikeImages[0];
---

<article class="group bg-bg-surface border border-border rounded-lg overflow-hidden hover:border-text-muted transition-colors duration-300">
  <a href={`/bikes/${bike.slug}`} class="block">
    {heroImage ? (
      <Image
        src={heroImage}
        alt={bike.name}
        class="aspect-[3/2] w-full object-cover grayscale"
        widths={[400, 600]}
        sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
        loading="lazy"
      />
    ) : (
      <div class="aspect-[3/2] bg-bg-surface-alt"></div>
    )}
  </a>

  <div class="p-6">
    <div class="flex items-start justify-between mb-2">
      <div>
        <h3 class="font-display text-xl font-semibold text-text-primary">
          <a href={`/bikes/${bike.slug}`} class="hover:text-text-secondary transition-colors duration-300">
            {bike.name}
          </a>
        </h3>
        {bike.nickname && (
          <span class="text-sm font-body text-text-muted italic">&ldquo;{bike.nickname}&rdquo;</span>
        )}
      </div>
      <span class="text-sm font-mono text-text-secondary whitespace-nowrap ml-2">{bike.year}</span>
    </div>

    <div class="flex items-center gap-2 mb-4">
      <span class="inline-block px-2 py-0.5 text-xs font-mono uppercase tracking-wider text-text-muted border border-accent-muted rounded">
        {bike.category}
      </span>
      <span class="text-sm font-body font-medium text-accent">
        ab {bike.pricePerDay} EUR / Tag
      </span>
    </div>

    <dl class="grid grid-cols-2 gap-x-3 gap-y-2 sm:gap-x-4 mb-6 text-sm">
      <div>
        <dt class="font-mono text-text-muted text-xs uppercase tracking-wider">Engine</dt>
        <dd class="font-body text-text-secondary">{bike.engine}</dd>
      </div>
      <div>
        <dt class="font-mono text-text-muted text-xs uppercase tracking-wider">Power</dt>
        <dd class="font-body text-text-secondary">{bike.power}</dd>
      </div>
      <div>
        <dt class="font-mono text-text-muted text-xs uppercase tracking-wider">Weight</dt>
        <dd class="font-body text-text-secondary">{bike.weight}</dd>
      </div>
      <div>
        <dt class="font-mono text-text-muted text-xs uppercase tracking-wider">Height</dt>
        <dd class="font-body text-text-secondary">{bike.seat}</dd>
      </div>
    </dl>

    <a
      href={bike.ripeUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="block w-full text-center px-6 py-3 bg-text-primary text-bg-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-text-secondary transition-colors duration-300"
    >
      Book via RIBE
    </a>
  </div>
</article>
