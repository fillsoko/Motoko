---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="relative min-h-[50vh] flex items-end overflow-hidden">
  <div class="absolute inset-0 bg-bg-surface" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/60 to-transparent"></div>
  </div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 pb-16 pt-32">
    <h1 class="font-display font-light text-5xl md:text-7xl tracking-wide mb-4">
      {title}
    </h1>
    {subtitle && (
      <p class="font-body text-text-secondary text-lg md:text-xl max-w-2xl leading-relaxed">
        {subtitle}
      </p>
    )}
  </div>
</section>
