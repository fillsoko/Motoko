---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  titleEn?: string;
  subtitle?: string;
  subtitleEn?: string;
  image?: ImageMetadata;
  fullHeight?: boolean;
}

const { title, titleEn, subtitle, subtitleEn, image, fullHeight = false } = Astro.props;
---

<section class:list={[
  'relative flex items-end overflow-hidden',
  fullHeight ? 'min-h-screen' : 'min-h-[50vh]',
]}>
  <div class="absolute inset-0" aria-hidden="true">
    {image ? (
      <Image
        src={image}
        alt=""
        class="w-full h-full object-cover grayscale"
        widths={[800, 1200, 1920]}
        sizes="100vw"
        loading="eager"
      />
    ) : (
      <div class="w-full h-full bg-bg-surface"></div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/40 to-transparent"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pb-12 md:pb-16">
    <div class="max-w-4xl">
      <h1
      class="font-display font-light text-[3.1rem] uppercase leading-[0.88] tracking-[0.06em] text-text-primary sm:text-[4.4rem] lg:text-[6.2rem]"
      data-i18n-de={title}
      data-i18n-en={titleEn || title}
    >
      {title}
    </h1>
    {subtitle && (
      <p
        class="mt-5 max-w-2xl font-body text-base leading-relaxed text-text-secondary sm:text-lg"
        data-i18n-de={subtitle}
        data-i18n-en={subtitleEn || subtitle}
      >
        {subtitle}
      </p>
    )}
    </div>
  </div>
</section>
