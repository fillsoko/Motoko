---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import SectionDivider from '../components/SectionDivider.astro';
import heroImage from '../assets/images/heroes/testimonials.webp';
---

<BaseLayout title="Gästebuch — motoko" description="Was unsere Fahrer über motoko sagen. Erfahrungsberichte von Motorradmietern.">
  <Nav />
  <main>
    <PageHero
      title="Gästebuch"
      titleEn="Guestbook"
      subtitle="Was unsere Mieter über ihre Erfahrung mit motoko sagen."
      subtitleEn="What our renters say about their experience with motoko."
      image={heroImage}
      fullHeight={true}
    />
    <SectionDivider />
    <Testimonials hideIntro={true} />
  </main>
  <Footer />
  <CookieBanner />
</BaseLayout>
