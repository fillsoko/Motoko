---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import PricingTable from '../components/PricingTable.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import SectionDivider from '../components/SectionDivider.astro';
import heroImage from '../../Graphics/Website/Handover.png';
---

<BaseLayout title="Preise — motoko" description="Alle Motorrad-Mietpreise auf einen Blick. Tages-, 3-Tages- und Wochentarife inklusive Vollkaskoversicherung.">
  <Nav />
  <main>
    <PageHero
      title="Preise"
      titleEn="Pricing"
      subtitle="Transparente Tarife für jedes Motorrad. Vollkaskoversicherung immer inklusive."
      subtitleEn="Transparent rates for every motorcycle. Comprehensive insurance always included."
      image={heroImage}
      fullHeight={true}
    />
    <SectionDivider />
    <PricingTable hideIntro={true} />
  </main>
  <Footer />
  <CookieBanner />
</BaseLayout>
