---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHero from '../components/PageHero.astro';
import Fleet from '../components/Fleet.astro';
import GearAccessories from '../components/GearAccessories.astro';
import AvailabilityCalendar from '../components/AvailabilityCalendar.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import SectionDivider from '../components/SectionDivider.astro';
import heroImage from '../assets/images/bikes/bmw-r-1200-gs/6893db91555a5.jpg';
---

<BaseLayout title="Fleet — motoko" description="Neun handverlesene Motorräder von sieben Herstellern. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung.">
  <Nav />
  <main>
    <PageHero
      title="Unsere Fleet"
      titleEn="Our Fleet"
      subtitle="Neun Motorräder, gewartet auf Touring-Standard. Jede Miete beinhaltet eine tägliche Vollkaskoversicherung."
      subtitleEn="Nine motorcycles, maintained to touring standard. Every rental includes daily comprehensive insurance."
      image={heroImage}
    />
    <SectionDivider />
    <Fleet />
    <SectionDivider label="Ausrüstung" />
    <GearAccessories />
    <SectionDivider label="Saison" />
    <AvailabilityCalendar />
  </main>
  <Footer />
  <CookieBanner />
</BaseLayout>
