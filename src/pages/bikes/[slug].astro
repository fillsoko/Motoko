---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { bikes } from '../../data/bikes';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return bikes.map((bike) => ({
    params: { slug: bike.slug },
    props: { bike },
  }));
};

const { bike } = Astro.props;

// Dynamically load bike images
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/bikes/**/*.webp',
  { eager: true }
);

const bikeImageEntries = Object.entries(allImages).filter(([path]) => path.includes(`/${bike.slug}/`));
const isImage = (image: ImageMetadata | undefined): image is ImageMetadata => Boolean(image);

const bikeImages = bike.images?.length
  ? bike.images
      .map((filename) => bikeImageEntries.find(([path]) => path.endsWith(`/${filename}`))?.[1].default)
      .filter(isImage)
  : bikeImageEntries
      .sort(([a], [b]) => {
        if (a.includes('hero.')) return -1;
        if (b.includes('hero.')) return 1;
        return a.localeCompare(b);
      })
      .map(([, mod]) => mod.default);

const heroImage = bikeImages[0];
const bikeBrand = bike.name.startsWith('Harley-Davidson')
  ? 'Harley-Davidson'
  : bike.name.split(' ')[0];
const motokoBookingHref = `/anfrage?interest=bike&brand=${encodeURIComponent(bikeBrand)}&booking=direct&bike=${encodeURIComponent(bike.name)}&bikeSlug=${encodeURIComponent(bike.slug)}`;
---

<BaseLayout title={`${bike.name} — motoko`} description={`${bike.name} mieten bei motoko. ${bike.engine}, ${bike.power}. Ab ${bike.pricePerDay} EUR pro Tag.`}>
  <Nav />

  <main class="pt-24 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Back link -->
      <a
        href="/fleet"
        class="inline-flex items-center gap-2 text-sm font-body text-text-muted hover:text-accent transition-colors duration-300 mb-8"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
        </svg>
        Alle Bikes
      </a>

      <!-- Hero image or placeholder -->
      {heroImage ? (
        <Image
          src={heroImage}
          alt={bike.name}
          class="aspect-[16/9] w-full object-cover rounded-lg mb-10 grayscale"
          widths={[600, 900, 1200]}
          sizes="(max-width: 768px) 100vw, 900px"
          loading="eager"
        />
      ) : (
        <div class="aspect-[16/9] bg-bg-surface-alt rounded-lg mb-10"></div>
      )}

      <!-- Additional images gallery -->
      {bikeImages.length > 1 && (
        <div class="grid grid-cols-3 gap-3 mb-10">
          {bikeImages.slice(1).map((img) => (
            <Image
              src={img}
              alt={bike.name}
              class="aspect-[3/2] w-full object-cover rounded grayscale"
              widths={[300, 400]}
              sizes="33vw"
              loading="lazy"
            />
          ))}
        </div>
      )}

      <!-- Header -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
        <div>
          <h1 class="font-display text-3xl md:text-5xl font-light text-text-primary">
            {bike.name}
          </h1>
          {bike.nickname && (
            <span class="text-lg font-body text-text-muted italic mt-1 block">
              &ldquo;{bike.nickname}&rdquo;
            </span>
          )}
        </div>
        <div class="flex items-center gap-3">
          <span class="inline-block px-3 py-1 text-xs font-mono uppercase tracking-wider text-text-muted border border-accent-muted rounded">
            {bike.category}
          </span>
          <span class="text-sm font-mono text-text-secondary">{bike.year}</span>
        </div>
      </div>

      <!-- Specs grid -->
      <dl class="grid grid-cols-2 md:grid-cols-3 gap-6 mb-10 p-6 bg-bg-surface border border-border rounded-lg">
        <div>
          <dt class="font-mono text-xs uppercase tracking-wider text-text-muted mb-1">Motor</dt>
          <dd class="font-body text-text-secondary">{bike.engine}</dd>
        </div>
        <div>
          <dt class="font-mono text-xs uppercase tracking-wider text-text-muted mb-1">Leistung</dt>
          <dd class="font-body text-text-secondary">{bike.power}</dd>
        </div>
        <div>
          <dt class="font-mono text-xs uppercase tracking-wider text-text-muted mb-1">Gewicht</dt>
          <dd class="font-body text-text-secondary">{bike.weight}</dd>
        </div>
        <div>
          <dt class="font-mono text-xs uppercase tracking-wider text-text-muted mb-1">Mindestgroesse</dt>
          <dd class="font-body text-text-secondary">{bike.seat}</dd>
        </div>
        <div>
          <dt class="font-mono text-xs uppercase tracking-wider text-text-muted mb-1">Baujahr</dt>
          <dd class="font-body text-text-secondary">{bike.year}</dd>
        </div>
        <div>
          <dt class="font-mono text-xs uppercase tracking-wider text-text-muted mb-1">Preis</dt>
          <dd class="font-body text-accent font-medium">ab {bike.pricePerDay} EUR / Tag</dd>
        </div>
      </dl>

      <div class="grid gap-6 md:grid-cols-[1.15fr_0.85fr] mb-10">
        <section class="rounded-lg border border-border bg-bg-surface p-6">
          <h2 class="font-display text-2xl md:text-3xl font-light text-text-primary mb-4">
            Zum Motorrad
          </h2>
          <p class="font-body text-text-secondary leading-relaxed mb-4">
            {bike.overview}
          </p>
          <p class="font-body text-text-secondary leading-relaxed">
            {bike.rideNote}
          </p>
        </section>

        <aside class="rounded-lg border border-border bg-bg-surface p-6">
          <h2 class="font-display text-2xl md:text-3xl font-light text-text-primary mb-4">
            Highlights
          </h2>
          <ul class="space-y-3">
            {bike.highlights.map((highlight) => (
              <li class="flex items-start gap-3 font-body text-text-secondary leading-relaxed">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
                <span>{highlight}</span>
              </li>
            ))}
          </ul>
        </aside>
      </div>

      <!-- CTA -->
      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href={bike.ripeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-4 bg-accent text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-accent-hover transition-colors duration-300 text-center"
        >
          Book via RIBE
        </a>
        <a
          href={motokoBookingHref}
          class="inline-block px-8 py-4 border border-border text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300 text-center"
        >
          Book via motoko
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
