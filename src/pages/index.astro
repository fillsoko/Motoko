---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import ValueProps from '../components/ValueProps.astro';
import Fleet from '../components/Fleet.astro';
import Faq from '../components/Faq.astro';
import InquiryWizard from '../components/InquiryWizard.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import SectionDivider from '../components/SectionDivider.astro';
---

<BaseLayout title="motoko — Motorcycle Rental & Tours">
  <Nav />
  <main>
    <Hero />
    <SectionDivider />
    <ValueProps />
    <SectionDivider label="Fleet" />
    <Fleet preview={true} />
    <SectionDivider label="FAQ" />
    <Faq />
    <SectionDivider label="Kontakt" />
    <InquiryWizard />
    <SectionDivider />
    <CtaSection />
  </main>
  <Footer />
  <CookieBanner />
</BaseLayout>
