---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { posts } from '../../data/posts';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

const { post } = Astro.props;

const formattedDate = new Date(post.date).toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${post.titleDe} — motoko`} description={post.excerptDe}>
  <Nav />

  <main class="pt-24 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Back link -->
      <a
        href="/journal"
        class="inline-flex items-center gap-2 text-sm font-body text-text-muted hover:text-accent transition-colors duration-300 mb-8"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
        </svg>
        <span data-i18n-de="Alle Beiträge" data-i18n-en="All Posts">Alle Beiträge</span>
      </a>

      <!-- Hero image placeholder -->
      <div class="aspect-[16/9] bg-bg-surface-alt rounded-lg mb-10"></div>

      <!-- Meta -->
      <div class="flex items-center gap-4 mb-6">
        <span class="inline-block px-2 py-0.5 text-xs font-mono uppercase tracking-wider text-text-muted border border-accent-muted rounded"
          data-i18n-de={post.category}
          data-i18n-en={post.categoryEn}
        >{post.category}</span>
        <time class="font-mono text-xs text-text-muted">{formattedDate}</time>
        <span class="font-mono text-xs text-text-muted">{post.readingTime}</span>
      </div>

      <!-- Title -->
      <h1 class="font-display text-3xl md:text-5xl font-light mb-6"
        data-i18n-de={post.titleDe}
        data-i18n-en={post.titleEn}
      >{post.titleDe}</h1>

      <!-- Lead paragraph -->
      <p class="font-body text-text-secondary text-lg leading-relaxed mb-10"
        data-i18n-de={post.excerptDe}
        data-i18n-en={post.excerptEn}
      >{post.excerptDe}</p>

      <!-- Placeholder body content -->
      <div class="prose-motoko space-y-6">
        <p class="font-body text-text-secondary leading-relaxed"
          data-i18n-de="Dieser Beitrag wird in Kürze mit vollständigem Inhalt ergänzt. Schau bald wieder vorbei oder folge uns auf Instagram für aktuelle Updates."
          data-i18n-en="This post will be updated with full content shortly. Check back soon or follow us on Instagram for the latest updates."
        >Dieser Beitrag wird in Kürze mit vollständigem Inhalt ergänzt. Schau bald wieder vorbei oder folge uns auf Instagram für aktuelle Updates.</p>
        <div class="aspect-[16/9] bg-bg-surface-alt rounded-lg"></div>
        <p class="font-body text-text-secondary leading-relaxed"
          data-i18n-de="Hast du Fragen zu diesem Thema? Schreib uns gerne über WhatsApp oder unser Kontaktformular."
          data-i18n-en="Have questions about this topic? Feel free to reach out via WhatsApp or our contact form."
        >Hast du Fragen zu diesem Thema? Schreib uns gerne über WhatsApp oder unser Kontaktformular.</p>
      </div>

      <!-- CTA -->
      <div class="mt-16 pt-8 border-t border-border-subtle">
        <a
          href="/journal"
          class="inline-block px-8 py-3 border border-border text-text-primary text-sm font-body font-medium uppercase tracking-widest rounded hover:bg-bg-surface transition-colors duration-300"
          data-i18n-de="Zurück zum Journal"
          data-i18n-en="Back to Journal"
        >Zurück zum Journal</a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
