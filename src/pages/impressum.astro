---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Impressum — motoko"
  description="Impressum der Motoko GmbH gem&auml;&szlig; &sect; 5 DDG."
>
  <Nav />
  <main class="pt-24 pb-24 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-display text-4xl md:text-5xl mb-8">Impressum</h1>

      <div class="space-y-10 font-body text-text-secondary">
        <section class="space-y-3">
          <h2 class="font-display text-2xl text-text-primary">Angaben gem&auml;&szlig; &sect; 5 DDG</h2>
          <p>
            Motoko GmbH<br />
            Waidmannstr. 7-9<br />
            60596 Frankfurt am Main<br />
            Deutschland
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="font-display text-2xl text-text-primary">Vertreten durch</h2>
          <p>Gesch&auml;ftsf&uuml;hrer: Tim Kowalke</p>
        </section>

        <section class="space-y-3">
          <h2 class="font-display text-2xl text-text-primary">Kontakt</h2>
          <p>
            Telefon: <a href="tel:+4917612345678" class="underline underline-offset-4">+49 176 12345678</a><br />
            E-Mail: <a href="mailto:[E-Mail ergänzen]" class="underline underline-offset-4">[E-Mail erg&auml;nzen]</a>
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="font-display text-2xl text-text-primary">Registereintrag</h2>
          <p>
            Eintragung im Handelsregister.<br />
            Registergericht: Amtsgericht Frankfurt am Main<br />
            Registernummer: HRB 135388
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="font-display text-2xl text-text-primary">Umsatzsteuer-ID</h2>
          <p>
            Umsatzsteuer-Identifikationsnummer gem&auml;&szlig; &sect; 27 a Umsatzsteuergesetz:<br />
            [USt-IdNr. erg&auml;nzen, falls vorhanden]
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="font-display text-2xl text-text-primary">Verantwortlich f&uuml;r den Inhalt</h2>
          <p>
            Tim Kowalke<br />
            Waidmannstr. 7-9<br />
            60596 Frankfurt am Main
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="font-display text-2xl text-text-primary">Hinweis</h2>
          <p>
            Bitte ersetzen Sie alle Platzhalter in eckigen Klammern vor dem Live-Betrieb durch die vollst&auml;ndigen Unternehmensangaben.
          </p>
        </section>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
