---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Impressum — motoko">
  <Nav />
  <main class="pt-24 pb-24 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-display text-4xl mb-8">Impressum</h1>
      <p class="text-text-secondary font-body">
        Motoko GmbH<br />
        [Address placeholder]<br />
        [City, PLZ]<br />
        Deutschland
      </p>
      <p class="text-text-muted font-body mt-4 text-sm">
        Content pending legal review.
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>
